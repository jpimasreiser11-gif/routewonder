---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Vídeos y rutas visuales | RouteWonder" description="Archivo visual de RouteWonder con shorts, guías y rutas narradas.">
  <section class="bg-rw-ocean px-4 py-20 text-rw-white sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="font-ui text-xs font-bold uppercase tracking-[0.28em] text-rw-gold">Archivo visual</p>
      <h1 class="mt-4 font-display text-5xl font-black leading-tight sm:text-7xl">Rutas que se entienden mirando.</h1>
      <p class="mt-5 max-w-2xl font-body text-lg leading-relaxed text-rw-sand/80">
        Vídeos cortos, mapas mentales y guías pensadas para decidir rápido: ir, guardar o descartar.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="rounded-full bg-rw-horizon px-6 py-3 font-ui text-sm font-bold text-white" href={`${base}videos/demo/`}>Ver vídeo principal</a>
        <a class="rounded-full border border-rw-white/20 px-6 py-3 font-ui text-sm font-bold text-rw-white" href={`${base}blog/`}>Leer guías</a>
      </div>
    </div>
  </section>
</BaseLayout>
