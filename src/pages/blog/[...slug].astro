---
import { getCollection, render } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";

export async function getStaticPaths() {
  const getEntrySlug = (entry) => (entry.slug || entry.id || "").replace(/\.md$/, "").replace(/^blog\//, "");
  const posts = await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });
  return posts.map((entry) => ({
    params: { slug: getEntrySlug(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = typeof entry.render === "function" ? await entry.render() : await render(entry);
---

<ArticleLayout post={entry} headings={headings}>
  <Content />
</ArticleLayout>
