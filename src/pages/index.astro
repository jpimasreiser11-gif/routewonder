---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/home/Hero.astro";
import CategoryGrid from "../components/home/CategoryGrid.astro";
import FeaturedArticles from "../components/home/FeaturedArticles.astro";
import NewsletterSignup from "../components/home/NewsletterSignup.astro";
import FlightLab from "../components/home/FlightLab.astro";
import EditorialDesk from "../components/home/EditorialDesk.astro";
import RoutePlanner from "../components/home/RoutePlanner.astro";
import IntroVideo from "../components/home/IntroVideo.astro";
---

<BaseLayout
  title="RouteWonder - Viajes Curiosos y Geografía Sorprendente"
  description="Revista digital independiente sobre exploración geográfica, rutas insólitas, destinos secretos y enigmas cartográficos."
>
  <!-- Hero Section -->
  <Hero />

  <!-- Horizontal Scroll of Category Pills -->
  <CategoryGrid />

  <RoutePlanner />

  <IntroVideo />

  <FlightLab />

  <EditorialDesk />

  <!-- Featured Blog Cards Grid -->
  <FeaturedArticles />

  <!-- Newsletter Signup CTA -->
  <NewsletterSignup />
</BaseLayout>
