---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout title="RouteWonder | Demo local" description="Viajes curiosos, rutas inteligentes y geografía sorprendente.">
  <section class="hero">
    <p class="badge">HERMES MEDIA · DRAFT LOCAL</p>
    <h1>RouteWonder</h1>
    <p>Viajes curiosos, rutas inteligentes y geografía sorprendente.</p>
    <div class="actions"><a href={`${base}demo/`}>Ver demo</a><a href={`${base}videos/demo/`}>Ver vídeo</a><a href={`${base}blog/`}>Ver blog</a></div>
  </section>
</BaseLayout>
