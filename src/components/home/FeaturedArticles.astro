---
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Sort by date descending and filter by featured, fallback to newest posts
const featuredPosts = posts
  .filter((post) => post.data.featured)
  .sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf())
  .slice(0, 5);

// If less than 5 featured posts, fill up with newest posts
if (featuredPosts.length < 5) {
  const remainingCount = 5 - featuredPosts.length;
  const nonFeaturedSorted = posts
    .filter((post) => !featuredPosts.some((fp) => fp.id === post.id))
    .sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf());
    
  featuredPosts.push(...nonFeaturedSorted.slice(0, remainingCount));
}

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const [lead, ...sidePosts] = featuredPosts;
const fallbackImages = [
  "/images/route-map.svg",
  "/images/route-alpine-rail.svg",
  "/images/route-coast.svg",
  "/images/route-city.svg",
  "/images/route-island.svg",
];

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString("es-ES", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}
---

<section class="relative overflow-hidden border-y border-rw-ink/10 bg-rw-sand py-16 dark:border-rw-white/10 sm:py-24">
  <div class="pointer-events-none absolute inset-0 opacity-70" style="background-image: linear-gradient(90deg, rgba(24,35,31,.07) 1px, transparent 1px), linear-gradient(rgba(24,35,31,.07) 1px, transparent 1px); background-size: 140px 140px;"></div>
  <div class="mx-auto max-w-[1500px] px-4 sm:px-6 lg:px-10">
    <div class="relative mb-11 grid gap-6 border-b border-rw-ink/10 pb-8 lg:grid-cols-[0.72fr_1fr] lg:items-end">
      <div>
        <h2 class="text-balance font-display text-4xl font-black leading-none tracking-[-0.025em] text-rw-ink dark:text-rw-ink sm:text-6xl">
          Historias que merecen abrir el mapa.
        </h2>
      </div>
      <div class="lg:justify-self-end">
        <p class="max-w-xl font-body text-xl leading-relaxed text-rw-ocean/78">
          Selección corta, editada a mano: rutas útiles, rarezas geográficas y destinos que cambian de tono cuando sabes dónde mirar.
        </p>
        <a href={`${base}blog/`} class="rw-luxury-link mt-5">Ver archivo completo</a>
      </div>
    </div>

    {lead && (
      <div class="grid gap-7 lg:grid-cols-12">
        <article class="group lg:col-span-7">
          <a href={`${base}blog/${lead.slug}/`} class="block focus:outline-none focus-visible:ring-2 focus-visible:ring-rw-horizon">
            <figure class="overflow-hidden rounded-[.85rem] border border-rw-ink/14 bg-rw-white p-3 shadow-[0_24px_80px_-62px_rgba(24,35,31,.75)]">
              <img
                src={lead.data.image || fallbackImages[0]}
                alt={lead.data.imageAlt || lead.data.title}
                loading="lazy"
                class="h-[430px] w-full rounded-[.45rem] object-cover saturate-[.86] transition duration-700 group-hover:scale-[1.025] sm:h-[560px]"
              />
            </figure>
            <div class="mt-5 grid gap-4 border-b border-rw-ink/10 pb-6 sm:grid-cols-[0.32fr_1fr]">
              <div class="font-mono text-[11px] font-black tracking-[0.04em] text-rw-horizon">
                {lead.data.category?.replace(/-/g, " ")}
                <span class="mt-2 block text-rw-mist">{formatDate(lead.data.publishedDate)}</span>
              </div>
              <div>
                <h3 class="text-balance font-display text-4xl font-black leading-[1.02] tracking-[-0.02em] text-rw-ink transition group-hover:text-rw-horizon sm:text-5xl">
                  {lead.data.title}
                </h3>
                <p class="mt-4 max-w-2xl font-ui text-base leading-relaxed text-rw-ocean/76">{lead.data.description}</p>
              </div>
            </div>
          </a>
        </article>

        <div class="grid gap-6 lg:col-span-5">
          {sidePosts.slice(0, 2).map((post, index) => (
            <article class={`group grid gap-4 ${index === 0 ? "md:grid-cols-[0.58fr_1fr]" : "md:grid-cols-[1fr_0.58fr]"}`}>
              <a href={`${base}blog/${post.slug}/`} class={`${index === 1 ? "md:order-2" : ""} block overflow-hidden rounded-[.8rem] border border-rw-ink/12 bg-rw-white p-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-rw-horizon shadow-[0_20px_58px_-48px_rgba(24,35,31,.8)]`}>
                <img
                  src={post.data.image || fallbackImages[(index + 1) % fallbackImages.length]}
                  alt={post.data.imageAlt || post.data.title}
                  loading="lazy"
                  class="h-64 w-full rounded-[.45rem] object-cover saturate-[.86] transition duration-700 group-hover:scale-[1.035] md:h-full"
                />
              </a>
              <div class="flex flex-col justify-center border-b border-rw-ink/10 pb-5">
                <p class="font-mono text-[11px] font-black tracking-[0.04em] text-rw-horizon">{post.data.category?.replace(/-/g, " ")}</p>
                <h3 class="mt-3 font-display text-3xl font-black leading-tight tracking-[-0.015em] text-rw-ink transition group-hover:text-rw-horizon">
                  <a href={`${base}blog/${post.slug}/`}>{post.data.title}</a>
                </h3>
                <p class="mt-3 font-ui text-sm leading-relaxed text-rw-ocean/72">{post.data.description}</p>
              </div>
            </article>
          ))}

          <div class="grid gap-0 border-y border-rw-ink/10">
            {sidePosts.slice(2, 4).map((post) => (
              <a href={`${base}blog/${post.slug}/`} class="group grid gap-3 border-b border-rw-ink/10 py-5 last:border-b-0 sm:grid-cols-[8rem_1fr]">
                <span class="font-ui text-[11px] font-black uppercase tracking-[0.18em] text-rw-mist">{formatDate(post.data.publishedDate)}</span>
                <span>
                  <strong class="block font-display text-2xl font-black leading-tight text-rw-ink transition group-hover:text-rw-horizon">{post.data.title}</strong>
                  <span class="mt-1 block font-ui text-sm leading-relaxed text-rw-ocean/68">{post.data.description}</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>
    )}
  </div>
</section>
