---
const panels = [
  {
    title: "Rutas con mapa mental",
    note: "Cada guía separa base, excursiones y margen libre para que el viaje no se convierta en una mudanza diaria.",
    image: "/images/route-map.svg",
    alt: "Lámina de ruta con paradas marcadas",
  },
  {
    title: "Visuales que explican la ruta",
    note: "No usamos imágenes como relleno: el mapa, el ritmo y la temporada ayudan a decidir si el destino encaja contigo.",
    image: "/images/route-mountain.svg",
    alt: "Relieve ilustrado con una ruta marcada entre miradores y bases de viaje",
  },
  {
    title: "Guías para elegir, no para acumular",
    note: "Presupuesto, transporte, compañía y ritmo pesan más que una lista interminable de imprescindibles.",
    image: "/images/route-coast.svg",
    alt: "Costa ilustrada con paradas, faro y margen para cambiar el ritmo del viaje",
  },
];
---

<section class="bg-rw-ocean py-16 text-rw-white sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
      <div>
        <p class="font-ui text-xs font-bold uppercase tracking-[0.28em] text-rw-gold">Atlas visual</p>
        <h2 class="mt-3 font-display text-4xl font-black leading-tight sm:text-6xl">
          Mapas, visuales y decisiones de viaje en una sola lectura.
        </h2>
        <p class="mt-5 font-body text-lg leading-relaxed text-rw-sand/82">
          RouteWonder funciona como una mesa de planificación: ves el lugar, entiendes la ruta y decides si merece tus días libres.
        </p>
        <a class="mt-8 inline-flex rounded-full bg-rw-horizon px-6 py-3 font-ui text-sm font-bold text-white transition hover:-translate-y-0.5" href="/blog/">
          Explorar guías
        </a>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        {panels.map((item, index) => (
          <article class={`group overflow-hidden rounded-3xl border border-rw-white/10 bg-rw-white/8 shadow-2xl shadow-rw-ink/20 ${index === 1 ? "sm:mt-12" : ""}`}>
            <div class="aspect-[4/3] overflow-hidden">
              <img src={item.image} alt={item.alt} loading="eager" class="h-full w-full object-cover object-center transition duration-700 group-hover:scale-105" />
            </div>
            <div class="p-5">
              <h3 class="font-display text-2xl font-bold">{item.title}</h3>
              <p class="mt-2 font-ui text-sm leading-relaxed text-rw-sand/75">{item.note}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
