---
import { originCities, routeDestinations } from "../../data/routePlannerData";
import { getCollection } from "astro:content";

const publishedPosts = await getCollection("blog", ({ data }) => !data.draft);
const plannerPosts = publishedPosts.filter((post) => post.data.planner);
const postBySlug = new Map(plannerPosts.map((post) => [post.slug, post]));

const budgetMap = { low: "bajo", medium: "medio", high: "alto" };
const transportMap = { car: "coche", train: "tren", flight: "avion", ferry: "ferry", bus: "bus" };
const seasonMap = { spring: "primavera", summer: "verano", autumn: "otono", winter: "invierno" };
const companionInterestMap = { couple: "pareja", solo: "solo", friends: "amigos", family: "familia" };
const interestMap = {
  nature: "naturaleza",
  culture: "cultura",
  beach: "playa",
  coastal: "playa",
  food: "gastronomia",
  driving: "raro",
  roadtrip: "raro",
  urban: "cultura",
  budget: "barato",
  family: "familia",
};

const stableImages = [
  "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1200&q=84",
  "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=1200&q=84",
  "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=84",
  "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1200&q=84",
  "https://images.unsplash.com/photo-1516483638261-f4dbaf036963?auto=format&fit=crop&w=1200&q=84",
];

function normalizeSlug(value: string) {
  return value.replace(/^\/?blog\//, "").replace(/\/$/, "");
}

function fromPlanner(post: (typeof plannerPosts)[number], index: number) {
  const planner = post.data.planner!;
  const interests = Array.from(new Set([
    ...planner.interests.map((item) => interestMap[item as keyof typeof interestMap] ?? item),
    ...planner.companion.map((item) => companionInterestMap[item as keyof typeof companionInterestMap] ?? item),
  ]));
  const image = post.data.image ?? stableImages[index % stableImages.length];
  return {
    id: post.slug,
    name: planner.destination,
    country: planner.country,
    lat: 40.42,
    lng: -3.70,
    interests,
    transport: planner.transport.map((item) => transportMap[item]),
    budget: budgetMap[planner.budget],
    seasons: planner.season.map((item) => seasonMap[item]),
    days: `${planner.duration} días`,
    article: `/blog/${post.slug}/`,
    photos: [
      image,
      stableImages[(index + 1) % stableImages.length],
      stableImages[(index + 2) % stableImages.length],
    ],
    highlights: post.data.tags?.slice(0, 3).map((tag) => tag.replace(/-/g, " ")) ?? [planner.destination],
    food: ["mercado local", "plato típico", "café de barrio"],
    stay: ["base céntrica para moverte fácil", "zona tranquila si prefieres descansar"],
    hotelUrl: `https://www.booking.com/searchresults.html?ss=${encodeURIComponent(planner.destination)}`,
    restaurantUrl: `https://www.google.com/maps/search/restaurantes+${encodeURIComponent(`${planner.destination} ${planner.country}`)}`,
    activityUrl: `https://www.getyourguide.com/s/?q=${encodeURIComponent(planner.destination)}`,
    mapUrl: `https://www.google.com/maps/search/${encodeURIComponent(`${planner.destination} ${planner.country}`)}`,
    description: post.data.description,
    title: post.data.title,
  };
}

const articleRoutes = plannerPosts.map(fromPlanner);
const articleRouteMap = new Map(articleRoutes.map((item) => [normalizeSlug(item.article), item]));
const rawPlannerDestinations = [
  ...routeDestinations.map((item) => {
    const enriched = articleRouteMap.get(normalizeSlug(item.article));
    if (!enriched) return item;
    return {
      ...item,
      title: enriched.title,
      description: enriched.description,
      budget: enriched.budget,
      transport: enriched.transport,
      seasons: enriched.seasons,
      days: enriched.days,
      interests: Array.from(new Set([...item.interests, ...enriched.interests])),
      photos: [
        enriched.photos[0],
        item.photos[1],
        item.photos[2],
      ],
    };
  }),
  ...articleRoutes.filter((item) => !routeDestinations.some((route) => normalizeSlug(route.article) === item.id)),
];
const destinationMap = new Map<string, (typeof rawPlannerDestinations)[number]>();
for (const item of rawPlannerDestinations) {
  const key = `${String(item.name).toLowerCase()}-${String(item.country).toLowerCase()}`;
  if (!destinationMap.has(key)) destinationMap.set(key, item);
}
const plannerDestinations = Array.from(destinationMap.values());

const totalDestinations = plannerDestinations.length;
const totalOrigins = originCities.length;
const totalPlaces = plannerDestinations.reduce((sum, item) => sum + item.highlights.length, 0);
---

<section id="planificador-rutas" class="bg-rw-sand py-16 dark:bg-rw-ink sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.5fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p class="font-ui text-xs font-bold uppercase tracking-[0.28em] text-rw-horizon">creador de rutas</p>
        <h2 class="mt-3 font-display text-4xl font-black leading-tight text-rw-ink dark:text-rw-white sm:text-5xl">
          Dime desde dónde sales y te preparo opciones con sentido.
        </h2>
        <p class="mt-4 font-ui text-base leading-relaxed text-rw-ocean/75 dark:text-rw-mist">
          Escribe tu ciudad, elige estilo de viaje y abre cada destino para ver fotos, paradas, comida, zonas para dormir y enlaces útiles.
        </p>

        <form class="mt-6 space-y-5 rounded-2xl border border-rw-mist/20 bg-rw-white p-5 shadow-sm dark:bg-rw-ocean/30" id="rw-trip-form">
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="rw-field sm:col-span-2">Vivo en
              <input id="rw-origin" list="rw-origin-cities" value="Barcelona" autocomplete="off" placeholder="Escribe tu ciudad: Madrid, Sevilla, Vigo..." />
              <datalist id="rw-origin-cities">
                {originCities.map((city) => <option value={city.name} />)}
              </datalist>
            </label>
            <button id="rw-location" class="sm:col-span-2 rounded-2xl border border-rw-horizon/25 bg-rw-horizon/10 px-4 py-3 text-left font-ui text-sm font-bold text-rw-horizon transition hover:bg-rw-horizon hover:text-white" type="button">
              Usar mi ubicación actual para calcular distancias reales
            </button>
            <label class="rw-field">Interés principal
              <select id="rw-interest">
                <option value="naturaleza">Naturaleza</option>
                <option value="cultura">Cultura</option>
                <option value="playa">Playa</option>
                <option value="gastronomia">Comer bien</option>
                <option value="raro">Lugares raros</option>
                <option value="barato">Ahorrar</option>
                <option value="familia">Fácil en familia</option>
              </select>
            </label>
            <label class="rw-field">Temporada
              <select id="rw-season">
                <option value="primavera">Primavera</option>
                <option value="verano">Verano</option>
                <option value="otono">Otoño</option>
                <option value="invierno">Invierno</option>
              </select>
            </label>
            <label class="rw-field">Días libres
              <input id="rw-days" type="number" min="2" max="21" value="5" />
            </label>
            <label class="rw-field">Con quién vas
              <select id="rw-companion">
                <option value="pareja">Pareja</option>
                <option value="solo">Solo</option>
                <option value="amigos">Amigos</option>
                <option value="familia">Familia</option>
              </select>
            </label>
          </div>

          <div>
            <p class="rw-label">Transporte preferido</p>
            <div class="mt-2 grid grid-cols-3 gap-2 sm:grid-cols-5" role="group" aria-label="Tipo de transporte">
              <button class="rw-chip is-active" type="button" data-filter="transport" data-value="avion">Avión</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="coche">Coche</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="tren">Tren</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="ferry">Ferry</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="bus">Bus</button>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <p class="rw-label">Presupuesto</p>
              <div class="mt-2 grid grid-cols-3 gap-2" role="group" aria-label="Presupuesto">
                <button class="rw-chip" type="button" data-filter="budget" data-value="bajo">Bajo</button>
                <button class="rw-chip is-active" type="button" data-filter="budget" data-value="medio">Medio</button>
                <button class="rw-chip" type="button" data-filter="budget" data-value="alto">Alto</button>
              </div>
            </div>
            <div>
              <p class="rw-label">Ritmo</p>
              <div class="mt-2 grid grid-cols-3 gap-2" role="group" aria-label="Ritmo">
                <button class="rw-chip" type="button" data-filter="pace" data-value="rapido">Rápido</button>
                <button class="rw-chip is-active" type="button" data-filter="pace" data-value="equilibrado">Medio</button>
                <button class="rw-chip" type="button" data-filter="pace" data-value="lento">Lento</button>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-4 gap-3 border-t border-rw-mist/15 pt-4 font-ui text-center text-xs">
            <div><strong id="rw-count" class="block text-2xl text-rw-horizon">8</strong>rutas</div>
            <div><strong class="block text-2xl text-rw-forest">{totalDestinations}</strong>destinos</div>
            <div><strong class="block text-2xl text-rw-gold">{totalPlaces}</strong>lugares</div>
            <div><strong class="block text-2xl text-rw-ocean dark:text-rw-white">{totalOrigins}</strong>salidas</div>
          </div>
        </form>
      </div>

      <div>
        <div id="rw-brief" class="mb-5 rounded-2xl border border-rw-horizon/20 bg-rw-horizon/5 p-5 font-ui text-sm leading-relaxed text-rw-ocean dark:text-rw-mist"></div>
        <div id="rw-results" class="grid gap-5"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .rw-label, .rw-field { font: 800 11px/1.2 "DM Sans", sans-serif; letter-spacing: .12em; text-transform: uppercase; color: rgba(22, 33, 62, .72); }
  .dark .rw-label, .dark .rw-field { color: var(--rw-mist); }
  .rw-field { display: grid; gap: 8px; }
  .rw-field input, .rw-field select { width: 100%; min-height: 46px; border-radius: 14px; border: 1px solid rgba(168,178,216,.35); background: rgba(250,250,250,.88); padding: 12px 14px; font: 600 14px/1.4 "DM Sans", sans-serif; color: var(--rw-ink); outline: none; }
  .rw-chip { min-height: 44px; border-radius: 12px; border: 1px solid rgba(168,178,216,.35); font: 800 11px/1.1 "DM Sans", sans-serif; color: var(--rw-ocean); background: rgba(250,250,250,.72); transition: transform 180ms ease, border-color 180ms ease, background 180ms ease, color 180ms ease; }
  .rw-chip:hover, .rw-chip.is-active { transform: translateY(-1px); border-color: var(--rw-horizon); background: var(--rw-horizon); color: white; }
  .rw-result-card { overflow: hidden; border-radius: 24px; border: 1px solid rgba(168,178,216,.22); background: rgba(250,250,250,.94); box-shadow: 0 12px 34px rgba(26,26,46,.08); }
  .dark .rw-result-card { background: rgba(22,33,62,.46); }
  .rw-gallery { display: grid; grid-template-columns: 1.35fr .65fr; gap: 8px; }
  .rw-gallery img { width: 100%; height: 100%; min-height: 176px; object-fit: cover; }
  .rw-gallery .side { display: grid; gap: 8px; }
  .rw-gallery .side img { min-height: 84px; }
  @media (max-width: 640px) { .rw-gallery { grid-template-columns: 1fr; } .rw-gallery .side { grid-template-columns: 1fr 1fr; } }
</style>

<script define:vars={{ routeDestinations: plannerDestinations, originCities }}>
  function setupRoutePlanner() {
    const root = document.getElementById('planificador-rutas');
    if (!root || root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';

    const results = root.querySelector('#rw-results');
    const count = root.querySelector('#rw-count');
    const brief = root.querySelector('#rw-brief');
    const state = {
      origin: 'Barcelona',
      interest: 'naturaleza',
      transport: 'avion',
      budget: 'medio',
      pace: 'equilibrado',
      season: 'primavera',
      days: 5,
      companion: 'pareja',
      originCoords: null,
    };

    function normalize(value) {
      return String(value || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
    }

    function resolveOrigin(value) {
      if (state.originCoords) return state.originCoords;
      const needle = normalize(value);
      return originCities.find((city) => normalize(city.name) === needle)
        || originCities.find((city) => normalize(city.name).includes(needle) || needle.includes(normalize(city.name)))
        || null;
    }

    function distanceKm(a, b) {
      if (!a || !b) return null;
      const toRad = (n) => n * Math.PI / 180;
      const R = 6371;
      const dLat = toRad(Number(b.lat) - Number(a.lat));
      const dLng = toRad(Number(b.lng) - Number(a.lng));
      const lat1 = toRad(Number(a.lat));
      const lat2 = toRad(Number(b.lat));
      const h = Math.sin(dLat / 2) ** 2 + Math.cos(lat1) * Math.cos(lat2) * Math.sin(dLng / 2) ** 2;
      return Math.round(2 * R * Math.asin(Math.sqrt(h)));
    }

    function scoreDestination(item, origin) {
      let score = 0;
      if (item.interests.includes(state.interest)) score += 34;
      if (item.transport.includes(state.transport)) score += 26;
      if (item.budget === state.budget) score += 15;
      if (item.seasons.includes(state.season)) score += 14;
      const distance = distanceKm(origin, item);
      if (distance !== null) {
        if (state.transport === 'coche') score += distance < 900 ? 18 : distance < 1500 ? 8 : -12;
        if (state.transport === 'tren') score += distance < 1100 ? 16 : -8;
        if (state.transport === 'avion') score += distance > 500 ? 12 : 4;
        if (state.transport === 'bus') score += distance < 800 ? 12 : -6;
      }
      const wantedDays = Number(state.days || 5);
      const itemDays = Number(String(item.days).match(/\d+/)?.[0] || 5);
      score += Math.max(0, 12 - Math.abs(wantedDays - itemDays) * 3);
      if (state.companion === 'familia' && item.interests.includes('familia')) score += 10;
      if (state.pace === 'lento' && itemDays >= 5) score += 7;
      if (state.pace === 'rapido' && itemDays <= 3) score += 7;
      return score;
    }

    function matchesVisibleSeason(item) {
      const selected = normalize(state.season);
      const text = normalize(`${item.name} ${item.description || ''} ${(item.tags || []).join(' ')}`);
      const conflicts = {
        primavera: ['invierno'],
        verano: ['invierno'],
        otono: ['verano pleno', 'agosto'],
        invierno: ['verano'],
      };
      return !(conflicts[selected] || []).some((word) => text.includes(word));
    }

    function modeLabel(item, distance) {
      const direct = item.transport.includes(state.transport) ? state.transport : item.transport[0];
      const km = distance === null ? 'distancia según salida' : `${distance.toLocaleString('es-ES')} km aprox.`;
      if (direct === 'coche') return `Coche · ${km}`;
      if (direct === 'tren') return `Tren · ${km}`;
      if (direct === 'ferry') return `Avión + ferry · ${km}`;
      if (direct === 'bus') return `Avión/bus · ${km}`;
      return `Avión · ${km}`;
    }

    function itinerary(item) {
      const total = Math.min(7, Math.max(2, Number(state.days || 5)));
      const stops = item.highlights;
      return Array.from({ length: total }, (_, index) => {
        const stop = stops[index % stops.length];
        if (index === 0) return `Día 1: llegada tranquila y paseo por ${stop}.`;
        if (index === total - 1) return `Día ${index + 1}: mañana libre y regreso sin apurar.`;
        return `Día ${index + 1}: ${stop}, comida local y una parada secundaria.`;
      });
    }

    function renderDetails(item) {
      return `
        <div class="mt-5 border-t border-rw-mist/20 pt-5">
          <div class="rw-gallery overflow-hidden rounded-2xl">
            <img src="${item.photos[0]}" alt="Vista de ${item.name}" loading="lazy">
            <div class="side">
              <img src="${item.photos[1]}" alt="Calle o paisaje de ${item.name}" loading="lazy">
              <img src="${item.photos[2]}" alt="Comida o ambiente de ${item.name}" loading="lazy">
            </div>
          </div>
          <div class="mt-5 grid gap-4 md:grid-cols-2">
            <div class="rounded-2xl bg-rw-sand p-4">
              <h4 class="font-display text-xl font-bold text-rw-ink">Ruta sugerida</h4>
              <ol class="mt-3 grid gap-2 font-ui text-sm text-rw-ocean/80">${itinerary(item).map((step) => `<li>${step}</li>`).join('')}</ol>
            </div>
            <div class="rounded-2xl bg-rw-sand p-4">
              <h4 class="font-display text-xl font-bold text-rw-ink">Qué mirar antes de reservar</h4>
              <ul class="mt-3 grid gap-2 font-ui text-sm text-rw-ocean/80">
                <li><strong>Visitas:</strong> ${item.highlights.join(', ')}.</li>
                <li><strong>Comer:</strong> ${item.food.join(', ')}.</li>
                <li><strong>Dormir:</strong> ${item.stay.join(' · ')}.</li>
              </ul>
            </div>
          </div>
          <div class="mt-4 flex flex-wrap gap-3">
            <a class="rounded-full bg-rw-ink px-4 py-2 font-ui text-xs font-bold uppercase tracking-wider text-white" href="${item.article}">Guía completa</a>
            <a class="rounded-full border border-rw-horizon/30 px-4 py-2 font-ui text-xs font-bold uppercase tracking-wider text-rw-horizon" href="${item.mapUrl}" rel="noopener noreferrer">Mapa</a>
            <a class="rounded-full border border-rw-horizon/30 px-4 py-2 font-ui text-xs font-bold uppercase tracking-wider text-rw-horizon" href="${item.hotelUrl}" rel="noopener noreferrer">Hoteles</a>
            <a class="rounded-full border border-rw-horizon/30 px-4 py-2 font-ui text-xs font-bold uppercase tracking-wider text-rw-horizon" href="${item.restaurantUrl}" rel="noopener noreferrer">Restaurantes</a>
            <a class="rounded-full border border-rw-horizon/30 px-4 py-2 font-ui text-xs font-bold uppercase tracking-wider text-rw-horizon" href="${item.activityUrl}" rel="noopener noreferrer">Actividades</a>
          </div>
        </div>`;
    }

    function render() {
      const origin = resolveOrigin(state.origin);
      const candidates = routeDestinations.filter(matchesVisibleSeason);
      const strict = candidates.filter((item) =>
        item.seasons.includes(state.season)
        && item.interests.includes(state.interest)
        && item.transport.includes(state.transport)
      );
      const seasonal = candidates.filter((item) =>
        item.seasons.includes(state.season)
        && item.interests.includes(state.interest)
      );
      const pool = strict.length ? strict : seasonal.length ? seasonal : candidates.filter((item) => item.seasons.includes(state.season));
      const ranked = pool
        .map((item) => {
          const distance = distanceKm(origin, item);
          return { ...item, distance, score: scoreDestination(item, origin) };
        })
        .sort((a, b) => b.score - a.score)
        .slice(0, 8);

      count.textContent = String(ranked.length);
      brief.replaceChildren();
      const briefStrong = document.createElement('strong');
      briefStrong.textContent = 'Salida:';
      const briefText = document.createTextNode(origin
        ? ` ${origin.name}. ${strict.length ? 'Coincidencias exactas' : 'Alternativas cercanas'} para ${state.season}, ${state.interest}, ${state.transport}, ${state.days} días y presupuesto ${state.budget}.`
        : ` ${state.origin}. No tengo coordenadas exactas de esa ciudad todavía, así que ordeno por estilo de viaje y logística.`);
      brief.append(briefStrong, briefText);

      results.replaceChildren();
      ranked.forEach((item, index) => {
        const article = document.createElement('article');
        article.className = 'rw-result-card';
        article.innerHTML = `
          <div class="grid gap-0 md:grid-cols-[0.95fr_1.05fr]">
            <img src="${item.photos[0]}" alt="Foto de ${item.name}" loading="lazy" class="h-full min-h-[260px] w-full object-cover">
            <div class="p-5 sm:p-6">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="font-ui text-xs font-bold uppercase tracking-[0.16em] text-rw-horizon">${item.country} · ${item.days}</p>
                  <h3 class="mt-1 font-display text-3xl font-black leading-tight text-rw-ink dark:text-rw-white">${item.name}</h3>
                </div>
                <span class="rounded-full bg-rw-horizon px-3 py-1 font-ui text-xs font-bold text-white">#${index + 1}</span>
              </div>
              <p class="mt-3 font-ui text-sm leading-relaxed text-rw-ocean/75 dark:text-rw-mist">${item.description || `${modeLabel(item, item.distance)}. Encaja por ${item.interests.slice(0, 3).join(', ')}.`}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                ${item.highlights.slice(0, 3).map((tag) => `<span class="rounded-full bg-rw-gold/15 px-3 py-1 font-ui text-xs font-bold text-rw-ocean dark:text-rw-sand">${tag}</span>`).join('')}
              </div>
              <button class="mt-5 rounded-full bg-rw-horizon px-5 py-3 font-ui text-xs font-bold uppercase tracking-wider text-white" type="button" data-detail="${item.id}">
                Ver fotos y ruta
              </button>
              <div class="hidden" data-panel="${item.id}">${renderDetails(item)}</div>
            </div>
          </div>`;
        results.appendChild(article);
      });

      results.querySelectorAll('[data-detail]').forEach((button) => {
        button.addEventListener('click', () => {
          const panel = results.querySelector(`[data-panel="${button.dataset.detail}"]`);
          if (!panel) return;
          panel.classList.toggle('hidden');
          button.textContent = panel.classList.contains('hidden') ? 'Ver fotos y ruta' : 'Ocultar detalles';
        });
      });
    }

    root.querySelectorAll('.rw-chip').forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter;
        state[filter] = button.dataset.value;
        root.querySelectorAll(`[data-filter="${filter}"]`).forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');
        render();
      });
    });

    const boundFields = {
      origin: '#rw-origin',
      interest: '#rw-interest',
      season: '#rw-season',
      days: '#rw-days',
      companion: '#rw-companion',
    };
    Object.entries(boundFields).forEach(([key, selector]) => {
      const input = root.querySelector(selector);
      if (!input) return;
      input.addEventListener('input', () => { state[key] = input.value; if (key === 'origin') state.originCoords = null; render(); });
      input.addEventListener('change', () => { state[key] = input.value; if (key === 'origin') state.originCoords = null; render(); });
    });

    const locationButton = root.querySelector('#rw-location');
    if (locationButton) {
      locationButton.addEventListener('click', () => {
        if (!navigator.geolocation) {
          locationButton.textContent = 'Tu navegador no permite ubicación. Escribe tu ciudad arriba.';
          return;
        }
        locationButton.textContent = 'Calculando desde tu ubicación...';
        navigator.geolocation.getCurrentPosition((position) => {
          state.origin = 'tu ubicación actual';
          state.originCoords = {
            name: 'tu ubicación actual',
            lat: position.coords.latitude,
            lng: position.coords.longitude,
          };
          const originInput = root.querySelector('#rw-origin');
          if (originInput) originInput.value = 'Ubicación actual';
          locationButton.textContent = 'Usando tu ubicación actual';
          render();
        }, () => {
          locationButton.textContent = 'No se pudo usar la ubicación. Escribe tu ciudad arriba.';
        }, { enableHighAccuracy: false, timeout: 8000, maximumAge: 900000 });
      });
    }

    render();
  }

  setupRoutePlanner();
  document.addEventListener('astro:after-swap', setupRoutePlanner);
</script>
