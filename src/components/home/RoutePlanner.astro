---

<section id="planificador-rutas" class="bg-rw-sand py-16 dark:bg-rw-ink sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.4fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p class="font-ui text-xs font-bold uppercase tracking-[0.28em] text-rw-horizon">planificador visual</p>
        <h2 class="mt-3 font-display text-4xl font-black leading-tight text-rw-ink dark:text-rw-white sm:text-5xl">
          Elige una ruta sin leer una guia entera.
        </h2>
        <p class="mt-4 font-ui text-base leading-relaxed text-rw-ocean/75 dark:text-rw-mist">
          Toca lo que te apetece y RouteWonder te muestra ideas con foto, tipo de transporte, coste aproximado y el primer paso.
        </p>

        <div class="mt-6 space-y-5 rounded-2xl border border-rw-mist/20 bg-rw-white p-5 shadow-sm dark:bg-rw-ocean/30">
          <div>
            <label for="rw-interest" class="font-ui text-xs font-bold uppercase tracking-wider text-rw-ocean/70 dark:text-rw-mist">Interes principal</label>
            <select id="rw-interest" class="mt-2 w-full rounded-xl border border-rw-mist/30 bg-rw-sand/60 px-4 py-3 font-ui text-sm text-rw-ink outline-none focus:border-rw-horizon dark:bg-rw-ink dark:text-rw-white">
              <option value="naturaleza">Naturaleza y paisajes</option>
              <option value="cultura">Cultura y ciudades</option>
              <option value="raro">Lugares raros</option>
              <option value="barato">Viaje economico</option>
            </select>
          </div>

          <div>
            <p class="font-ui text-xs font-bold uppercase tracking-wider text-rw-ocean/70 dark:text-rw-mist">Transporte</p>
            <div class="mt-2 grid grid-cols-3 gap-2" role="group" aria-label="Tipo de transporte">
              <button class="rw-chip is-active" type="button" data-filter="transport" data-value="avion">Avion</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="coche">Coche</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="tren">Tren</button>
            </div>
          </div>

          <div>
            <p class="font-ui text-xs font-bold uppercase tracking-wider text-rw-ocean/70 dark:text-rw-mist">Presupuesto</p>
            <div class="mt-2 grid grid-cols-3 gap-2" role="group" aria-label="Presupuesto">
              <button class="rw-chip is-active" type="button" data-filter="budget" data-value="bajo">Bajo</button>
              <button class="rw-chip" type="button" data-filter="budget" data-value="medio">Medio</button>
              <button class="rw-chip" type="button" data-filter="budget" data-value="alto">Alto</button>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-3 border-t border-rw-mist/15 pt-4 font-ui text-center text-xs">
            <div>
              <strong id="rw-count" class="block text-2xl text-rw-horizon">0</strong>
              ideas
            </div>
            <div>
              <strong class="block text-2xl text-rw-forest">3</strong>
              pasos
            </div>
            <div>
              <strong class="block text-2xl text-rw-gold">0</strong>
              pagos
            </div>
          </div>
        </div>
      </div>

      <div>
        <div id="rw-results" class="grid gap-5 sm:grid-cols-2"></div>
        <div class="mt-6 rounded-2xl border border-rw-horizon/20 bg-rw-horizon/5 p-5">
          <h3 class="font-display text-2xl font-bold text-rw-ink dark:text-rw-white">Escaner de viaje</h3>
          <div class="mt-4 grid gap-3 sm:grid-cols-3">
            <a href="/blog/?category=viaje-economico" class="rw-scan-link">
              <span>Vuelos</span>
              <strong>Buscar rutas baratas</strong>
            </a>
            <a href="/blog/?category=rutas-sorprendentes" class="rw-scan-link">
              <span>Coche</span>
              <strong>Rutas circulares</strong>
            </a>
            <a href="/blog/?category=destinos-secretos" class="rw-scan-link">
              <span>Ideas</span>
              <strong>Segun intereses</strong>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .rw-chip {
    min-height: 44px;
    border-radius: 12px;
    border: 1px solid rgba(168, 178, 216, 0.35);
    font: 700 12px/1.1 "DM Sans", sans-serif;
    color: var(--rw-ocean);
    background: rgba(250, 250, 250, 0.72);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease, color 180ms ease;
  }
  .rw-chip:hover,
  .rw-chip.is-active {
    transform: translateY(-1px);
    border-color: var(--rw-horizon);
    background: var(--rw-horizon);
    color: white;
  }
  .rw-scan-link {
    display: grid;
    gap: 2px;
    min-height: 84px;
    border-radius: 14px;
    border: 1px solid rgba(233, 69, 96, 0.18);
    padding: 14px;
    background: rgba(250, 250, 250, 0.72);
  }
  .rw-scan-link span {
    font: 800 10px/1 "DM Sans", sans-serif;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--rw-horizon);
  }
  .rw-scan-link strong {
    color: var(--rw-ink);
    font: 800 15px/1.2 "DM Sans", sans-serif;
  }
</style>

<script define:vars={{ destinations }}>
  function setupRoutePlanner() {
    const root = document.getElementById('planificador-rutas');
    if (!root || root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';

    const results = root.querySelector('#rw-results');
    const count = root.querySelector('#rw-count');
    const interest = root.querySelector('#rw-interest');
    const state = { interest: 'naturaleza', transport: 'avion', budget: 'bajo' };

    function scoreDestination(item) {
      let score = 0;
      if (item.interests.includes(state.interest)) score += 3;
      if (item.interests.includes(state.transport)) score += 2;
      if (item.budget === state.budget) score += 2;
      return score;
    }

    function render() {
      const ranked = destinations
        .map((item) => ({ ...item, score: scoreDestination(item) }))
        .sort((a, b) => b.score - a.score)
        .slice(0, 4);

      count.textContent = String(ranked.filter((item) => item.score > 0).length || ranked.length);
      results.replaceChildren();

      ranked.forEach((item, index) => {
        const article = document.createElement('article');
        article.className = 'overflow-hidden rounded-2xl border border-rw-mist/20 bg-rw-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl dark:bg-rw-ocean/35';
        article.innerHTML = `
          <div class="relative aspect-[4/3] overflow-hidden">
            <img src="${item.image}" alt="${item.alt}" loading="lazy" class="h-full w-full object-cover">
            <div class="absolute left-3 top-3 rounded-full bg-rw-ink/75 px-3 py-1 font-ui text-[10px] font-bold uppercase tracking-wider text-white">${item.route}</div>
          </div>
          <div class="p-5">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="font-display text-2xl font-bold text-rw-ink dark:text-rw-white">${item.name}</h3>
                <p class="font-ui text-xs font-bold uppercase tracking-wider text-rw-horizon">${item.country} · ${item.days}</p>
              </div>
              <span class="rounded-full bg-rw-gold/15 px-3 py-1 font-ui text-xs font-bold text-rw-ocean dark:text-rw-sand">${index + 1}</span>
            </div>
            <p class="mt-3 font-ui text-sm leading-relaxed text-rw-ocean/75 dark:text-rw-mist">${item.why}</p>
            <ol class="mt-4 grid gap-2 font-ui text-xs text-rw-ocean/80 dark:text-rw-mist">
              ${item.steps.map((step) => `<li class="rounded-lg bg-rw-sand/60 px-3 py-2 dark:bg-rw-ink/60">${step}</li>`).join('')}
            </ol>
          </div>
        `;
        results.appendChild(article);
      });
    }

    root.querySelectorAll('.rw-chip').forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter;
        const value = button.dataset.value;
        state[filter] = value;
        root.querySelectorAll(`[data-filter="${filter}"]`).forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');
        render();
      });
    });

    interest.addEventListener('change', () => {
      state.interest = interest.value;
      render();
    });

    render();
  }

  setupRoutePlanner();
  document.addEventListener('astro:after-swap', setupRoutePlanner);
</script>
