---
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const normalize = (value = "") =>
  value
    .toString()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase();

const inferBudget = (text: string) => {
  if (/barato|economico|gratis|sin arruinar|menos de|low cost|mochil/i.test(text)) return "bajo";
  if (/lujo|caro|noruega|islandia|japon|lofoten|skye|alto/i.test(text)) return "alto";
  return "medio";
};

const inferTransport = (text: string, category: string) => {
  const modes = new Set<string>();
  if (/avion|vuelo|volar|isla|madeira|malta|corfu|naxos|sicilia|japon/i.test(text)) modes.add("avion");
  if (/coche|carretera|road|ruta|conducir|pueblos|costa|interior/i.test(text) || category === "rutas-sorprendentes") modes.add("coche");
  if (/tren|rail|estacion|suiza|utrecht|gante|brujas|oporto/i.test(text) || category === "viaje-rapido") modes.add("tren");
  if (/ferry|isla|aran|corfu|naxos|menorca|malta/i.test(text)) modes.add("ferry");
  if (/bus|marruecos|estambul|mostar|sarajevo/i.test(text)) modes.add("bus");
  if (modes.size === 0) modes.add("avion");
  return [...modes];
};

const inferInterests = (text: string, category: string) => {
  const interests = new Set<string>();
  if (/playa|isla|costa|lago|mar|cala/i.test(text)) interests.add("playa");
  if (/bosque|montana|fiordo|lago|naturaleza|picos|lofoten|skye|bled/i.test(text)) interests.add("naturaleza");
  if (/ciudad|capital|barrios|granada|riga|tallin|vilna|estambul|gante|brujas/i.test(text)) interests.add("cultura");
  if (/comer|gastronomia|vino|duero|oporto|cadiz|sicilia/i.test(text)) interests.add("gastronomia");
  if (/raro|extrano|curios|mapa|frontera|fantasma|subterranea|volcan/i.test(text)) interests.add("raro");
  if (/barato|economico|sin arruinar|menos de/i.test(text) || category === "viaje-economico") interests.add("barato");
  if (/familia|ninos|sin coches|lento/i.test(text)) interests.add("familia");
  if (category === "lugares-de-pelicula") interests.add("raro");
  if (interests.size === 0) interests.add("cultura");
  return [...interests];
};

const inferSeason = (text: string) => {
  const seasons = new Set<string>();
  if (/primavera|abril|mayo|flores|verde/i.test(text)) seasons.add("primavera");
  if (/verano|playa|isla|lago/i.test(text)) seasons.add("verano");
  if (/otono|septiembre|octubre|noviembre|fuera de agosto/i.test(text)) seasons.add("otono");
  if (/invierno|navidad|frio|nieve/i.test(text)) seasons.add("invierno");
  if (seasons.size === 0) ["primavera", "otono"].forEach((s) => seasons.add(s));
  return [...seasons];
};

const inferCompanions = (text: string) => {
  const companions = new Set(["pareja", "amigos"]);
  if (/solo|personal|urbano/i.test(text)) companions.add("solo");
  if (/familia|ninos|sin coches|tren/i.test(text)) companions.add("familia");
  return [...companions];
};

const inferPace = (text: string) => {
  if (/72 horas|un dia|rapido|fin de semana|capitales/i.test(text)) return "rapido";
  if (/sin prisa|lento|sin correr|islas sin coches|rural/i.test(text)) return "lento";
  return "equilibrado";
};

const inferDays = (text: string) => {
  const match = text.match(/(\d+)\s*(dias|días|h|horas)/i);
  if (match) return match[0].replace("h", " horas");
  if (/fin de semana|72 horas/i.test(text)) return "3 días";
  if (/japon|cruzar europa/i.test(text)) return "10 días";
  if (/isla|coche|ruta/i.test(text)) return "5 días";
  return "4 días";
};

const guides = posts
  .sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf())
  .map((post) => {
    const text = `${post.data.title} ${post.data.description} ${(post.data.tags || []).join(" ")} ${post.data.category}`;
    const category = post.data.category;
    const transport = inferTransport(text, category);
    return {
      id: post.slug,
      name: post.data.title.replace(/:.*$/, ""),
      title: post.data.title,
      country: (post.data.tags || []).find((tag) => ["espana", "españa", "portugal", "francia", "italia", "grecia", "noruega", "japon", "marruecos", "turquia"].includes(normalize(tag))) || "guía RouteWonder",
      interests: inferInterests(text, category),
      transport,
      budget: inferBudget(text),
      companions: inferCompanions(text),
      pace: inferPace(text),
      seasons: inferSeason(text),
      days: inferDays(text),
      route: transport.slice(0, 2).map((item) => item.charAt(0).toUpperCase() + item.slice(1)).join(" + "),
      image: post.data.image || "/og-default.jpg",
      alt: post.data.imageAlt || `Imagen editorial para ${post.data.title}`,
      why: post.data.description,
      url: `/blog/${post.slug}/`,
      category,
    };
  });

const totalGuides = guides.length;
---

<section id="planificador-rutas" class="bg-rw-sand py-16 dark:bg-rw-ink sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[0.95fr_1.45fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p class="font-ui text-xs font-bold uppercase tracking-[0.28em] text-rw-horizon">planificador editorial</p>
        <h2 class="mt-3 font-display text-4xl font-black leading-tight text-rw-ink dark:text-rw-white sm:text-5xl">
          Encuentra una guía real según cómo quieres viajar.
        </h2>
        <p class="mt-4 font-ui text-base leading-relaxed text-rw-ocean/75 dark:text-rw-mist">
          El filtro trabaja con artículos publicados de RouteWonder. Cada resultado abre una guía concreta, con mapa, contexto y próximos pasos.
        </p>

        <form class="mt-6 space-y-5 rounded-2xl border border-rw-mist/20 bg-rw-white p-5 shadow-sm dark:bg-rw-ocean/30" id="rw-trip-form">
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="rw-field">Salida
              <select id="rw-origin"><option>Barcelona</option><option>Madrid</option><option>Valencia</option><option>Málaga</option><option>Bilbao</option><option>Lisboa</option><option>Otra ciudad</option></select>
            </label>
            <label class="rw-field">Interés principal
              <select id="rw-interest"><option value="naturaleza">Naturaleza</option><option value="cultura">Cultura</option><option value="playa">Playa</option><option value="gastronomia">Gastronomía</option><option value="raro">Lugares raros</option><option value="barato">Viaje económico</option><option value="familia">Familia</option></select>
            </label>
            <label class="rw-field">Con quién vas
              <select id="rw-companion"><option value="pareja">Pareja</option><option value="solo">Solo</option><option value="amigos">Amigos</option><option value="familia">Familia</option></select>
            </label>
            <label class="rw-field">Temporada
              <select id="rw-season"><option value="primavera">Primavera</option><option value="verano">Verano</option><option value="otono">Otoño</option><option value="invierno">Invierno</option></select>
            </label>
          </div>

          <div>
            <p class="rw-label">Transporte preferido</p>
            <div class="mt-2 grid grid-cols-3 gap-2 sm:grid-cols-5" role="group" aria-label="Tipo de transporte">
              <button class="rw-chip is-active" type="button" data-filter="transport" data-value="avion">Avión</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="coche">Coche</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="tren">Tren</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="ferry">Ferry</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="bus">Bus</button>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <p class="rw-label">Presupuesto</p>
              <div class="mt-2 grid grid-cols-3 gap-2" role="group" aria-label="Presupuesto">
                <button class="rw-chip is-active" type="button" data-filter="budget" data-value="bajo">Bajo</button>
                <button class="rw-chip" type="button" data-filter="budget" data-value="medio">Medio</button>
                <button class="rw-chip" type="button" data-filter="budget" data-value="alto">Alto</button>
              </div>
            </div>
            <div>
              <p class="rw-label">Ritmo</p>
              <div class="mt-2 grid grid-cols-3 gap-2" role="group" aria-label="Ritmo">
                <button class="rw-chip" type="button" data-filter="pace" data-value="rapido">Rápido</button>
                <button class="rw-chip is-active" type="button" data-filter="pace" data-value="equilibrado">Medio</button>
                <button class="rw-chip" type="button" data-filter="pace" data-value="lento">Lento</button>
              </div>
            </div>
          </div>

          <label class="rw-field">Notas del viaje
            <textarea id="rw-notes" rows="3" placeholder="Ejemplo: quiero evitar calor extremo, ir con maleta pequeña y tener una tarde tranquila."></textarea>
          </label>

          <div class="grid grid-cols-3 gap-3 border-t border-rw-mist/15 pt-4 font-ui text-center text-xs">
            <div><strong id="rw-count" class="block text-2xl text-rw-horizon">0</strong>guías</div>
            <div><strong class="block text-2xl text-rw-forest">{totalGuides}</strong>artículos</div>
            <div><strong class="block text-2xl text-rw-gold">6</strong>filtros</div>
          </div>
        </form>
      </div>

      <div>
        <div id="rw-brief" class="mb-5 rounded-2xl border border-rw-horizon/20 bg-rw-horizon/5 p-5 font-ui text-sm leading-relaxed text-rw-ocean dark:text-rw-mist"></div>
        <div id="rw-results" class="grid gap-5 sm:grid-cols-2"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .rw-label, .rw-field { font: 800 11px/1.2 "DM Sans", sans-serif; letter-spacing: .12em; text-transform: uppercase; color: rgba(22, 33, 62, .72); }
  .dark .rw-label, .dark .rw-field { color: var(--rw-mist); }
  .rw-field { display: grid; gap: 8px; }
  .rw-field select, .rw-field textarea { width: 100%; border-radius: 14px; border: 1px solid rgba(168,178,216,.35); background: rgba(250,250,250,.82); padding: 12px 14px; font: 600 14px/1.4 "DM Sans", sans-serif; color: var(--rw-ink); outline: none; }
  .rw-field textarea { resize: vertical; min-height: 92px; text-transform: none; letter-spacing: 0; }
  .rw-chip { min-height: 44px; border-radius: 12px; border: 1px solid rgba(168,178,216,.35); font: 800 11px/1.1 "DM Sans", sans-serif; color: var(--rw-ocean); background: rgba(250,250,250,.72); transition: transform 180ms ease, border-color 180ms ease, background 180ms ease, color 180ms ease; }
  .rw-chip:hover, .rw-chip.is-active { transform: translateY(-1px); border-color: var(--rw-horizon); background: var(--rw-horizon); color: white; }
</style>

<script define:vars={{ guides }}>
  function setupRoutePlanner() {
    const root = document.getElementById('planificador-rutas');
    if (!root || root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';
    const results = root.querySelector('#rw-results');
    const count = root.querySelector('#rw-count');
    const brief = root.querySelector('#rw-brief');
    const state = { interest: 'naturaleza', transport: 'avion', budget: 'bajo', companion: 'pareja', pace: 'equilibrado', season: 'primavera', origin: 'Barcelona', notes: '' };
    const fields = { interest: '#rw-interest', companion: '#rw-companion', season: '#rw-season', origin: '#rw-origin', notes: '#rw-notes' };

    function includes(value, list) { return Array.isArray(list) && list.includes(value); }
    function scoreGuide(item) {
      let score = 0;
      if (includes(state.interest, item.interests)) score += 4;
      if (includes(state.transport, item.transport)) score += 3;
      if (item.budget === state.budget) score += 2;
      if (includes(state.companion, item.companions)) score += 2;
      if (item.pace === state.pace) score += 1;
      if (includes(state.season, item.seasons)) score += 2;
      return score;
    }
    function render() {
      const rankedAll = guides.map((item) => ({ ...item, score: scoreGuide(item) })).sort((a, b) => b.score - a.score);
      const strong = rankedAll.filter((item) => item.score > 0);
      const ranked = (strong.length ? strong : rankedAll).slice(0, 6);
      count.textContent = String(ranked.length);
      const first = ranked[0];
      brief.innerHTML = `<strong>Brief generado:</strong> salida desde ${state.origin}, ritmo ${state.pace}, presupuesto ${state.budget}, interés ${state.interest} y transporte ${state.transport}. Primera guía: <strong>${first.title}</strong>. ${state.notes ? 'Nota añadida: ' + state.notes : 'Ajusta filtros para ver guías distintas.'}`;
      results.replaceChildren();
      ranked.forEach((item, index) => {
        const article = document.createElement('article');
        article.className = 'overflow-hidden rounded-2xl border border-rw-mist/20 bg-rw-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl dark:bg-rw-ocean/35';
        article.innerHTML = `
          <a href="${item.url}" class="block">
            <div class="relative aspect-[4/3] overflow-hidden">
              <img src="${item.image}" alt="${item.alt}" loading="lazy" class="h-full w-full object-cover">
              <div class="absolute left-3 top-3 rounded-full bg-rw-ink/75 px-3 py-1 font-ui text-[10px] font-bold uppercase tracking-wider text-white">${item.route}</div>
              <div class="absolute right-3 top-3 rounded-full bg-rw-horizon px-3 py-1 font-ui text-xs font-bold text-white">${item.score} pts</div>
            </div>
            <div class="p-5">
              <div class="flex items-start justify-between gap-3">
                <div><h3 class="font-display text-2xl font-bold text-rw-ink dark:text-rw-white">${item.title}</h3><p class="font-ui text-xs font-bold uppercase tracking-wider text-rw-horizon">${item.country} · ${item.days}</p></div>
                <span class="rounded-full bg-rw-gold/15 px-3 py-1 font-ui text-xs font-bold text-rw-ocean dark:text-rw-sand">#${index + 1}</span>
              </div>
              <p class="mt-3 font-ui text-sm leading-relaxed text-rw-ocean/75 dark:text-rw-mist">${item.why}</p>
              <span class="mt-4 inline-flex rounded-full bg-rw-ink px-4 py-2 font-ui text-xs font-bold uppercase tracking-wider text-white">Leer guía</span>
            </div>
          </a>`;
        results.appendChild(article);
      });
    }
    root.querySelectorAll('.rw-chip').forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter;
        state[filter] = button.dataset.value;
        root.querySelectorAll(`[data-filter="${filter}"]`).forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');
        render();
      });
    });
    Object.entries(fields).forEach(([key, selector]) => {
      const input = root.querySelector(selector);
      if (!input) return;
      input.addEventListener('input', () => { state[key] = input.value; render(); });
      input.addEventListener('change', () => { state[key] = input.value; render(); });
    });
    render();
  }
  setupRoutePlanner();
  document.addEventListener('astro:after-swap', setupRoutePlanner);
</script>
