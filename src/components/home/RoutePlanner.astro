---
import { originCities, routeDestinations } from "../../data/routePlannerData";
import { getCollection } from "astro:content";
import { getRouteVisualSet } from "../../lib/routeVisuals";
import { getContentSlug } from "../../lib/contentSlug";

const publishedPosts = await getCollection("blog", ({ data }) => !data.draft);
const plannerPosts = publishedPosts.filter((post) => post.data.planner);
const postBySlug = new Map(plannerPosts.map((post) => [getContentSlug(post), post]));

const budgetMap = { low: "bajo", medium: "medio", high: "alto" };
const transportMap = { car: "coche", train: "tren", flight: "avion", ferry: "ferry", bus: "bus" };
const seasonMap = { spring: "primavera", summer: "verano", autumn: "otono", winter: "invierno" };
const companionInterestMap = { couple: "pareja", solo: "solo", friends: "amigos", family: "familia" };
const interestMap = {
  nature: "naturaleza",
  culture: "cultura",
  beach: "playa",
  coastal: "playa",
  food: "gastronomia",
  driving: "raro",
  roadtrip: "raro",
  urban: "cultura",
  budget: "barato",
  family: "familia",
};

function normalizeSlug(value: string) {
  return value.replace(/^\/?blog\//, "").replace(/\/$/, "");
}

function fromPlanner(post: (typeof plannerPosts)[number]) {
  const planner = post.data.planner!;
  const slug = getContentSlug(post);
  const interests = Array.from(new Set([
    ...planner.interests.map((item) => interestMap[item as keyof typeof interestMap] ?? item),
    ...planner.companion.map((item) => companionInterestMap[item as keyof typeof companionInterestMap] ?? item),
  ]));
  const fallbackVisuals = getRouteVisualSet(`${slug} ${post.data.category} ${planner.destination} ${planner.country}`);
  const visuals = [
    `/images/editorial/${slug}-panel-1.svg`,
    `/images/editorial/${slug}-panel-2.svg`,
    post.data.image || fallbackVisuals[0],
  ];
  return {
    id: slug,
    name: planner.destination,
    country: planner.country,
    lat: 40.42,
    lng: -3.70,
    interests,
    transport: planner.transport.map((item) => transportMap[item]),
    budget: budgetMap[planner.budget],
    seasons: planner.season.map((item) => seasonMap[item]),
    days: `${planner.duration} días`,
    article: `/blog/${slug}/`,
    photos: visuals,
    highlights: post.data.tags?.slice(0, 3).map((tag) => tag.replace(/-/g, " ")) ?? [planner.destination],
    food: ["mercado local", "plato típico", "café de barrio"],
    stay: ["base céntrica para moverte fácil", "zona tranquila si prefieres descansar"],
    hotelUrl: `https://www.booking.com/searchresults.html?ss=${encodeURIComponent(planner.destination)}`,
    restaurantUrl: `https://www.google.com/maps/search/restaurantes+${encodeURIComponent(`${planner.destination} ${planner.country}`)}`,
    activityUrl: `https://www.getyourguide.com/s/?q=${encodeURIComponent(planner.destination)}`,
    mapUrl: `https://www.google.com/maps/search/${encodeURIComponent(`${planner.destination} ${planner.country}`)}`,
    description: post.data.description,
    title: post.data.title,
  };
}

const articleRoutes = plannerPosts.map(fromPlanner);
const articleRouteMap = new Map(articleRoutes.map((item) => [normalizeSlug(item.article), item]));
const rawPlannerDestinations = [
  ...routeDestinations.map((item) => {
    const enriched = articleRouteMap.get(normalizeSlug(item.article));
    if (!enriched) return item;
    return {
      ...item,
      title: enriched.title,
      description: enriched.description,
      budget: enriched.budget,
      transport: enriched.transport,
      seasons: enriched.seasons,
      days: enriched.days,
      interests: Array.from(new Set([...item.interests, ...enriched.interests])),
      photos: enriched.photos,
    };
  }),
  ...articleRoutes.filter((item) => !routeDestinations.some((route) => normalizeSlug(route.article) === item.id)),
];
const destinationMap = new Map<string, (typeof rawPlannerDestinations)[number]>();
for (const item of rawPlannerDestinations) {
  const key = `${String(item.name).toLowerCase()}-${String(item.country).toLowerCase()}`;
  if (!destinationMap.has(key)) destinationMap.set(key, item);
}
const plannerDestinations = Array.from(destinationMap.values());

const totalDestinations = plannerDestinations.length;
const totalOrigins = originCities.length;
const totalPlaces = plannerDestinations.reduce((sum, item) => sum + item.highlights.length, 0);
---

<section id="planificador-rutas" class="relative overflow-hidden bg-rw-ink py-16 text-rw-white dark:bg-rw-ink sm:py-24">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-rw-gold/20"></div>
  <div class="pointer-events-none absolute inset-0 opacity-55" style="background-image: linear-gradient(90deg, rgba(245,244,238,.08) 1px, transparent 1px), linear-gradient(rgba(245,244,238,.08) 1px, transparent 1px); background-size: 112px 112px;"></div>
  <div class="mx-auto max-w-[1500px] px-4 sm:px-6 lg:px-10">
    <div class="grid gap-10 lg:grid-cols-[0.82fr_1.48fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p data-i18n="planner.kicker" class="font-mono text-xs font-black tracking-[0.04em] text-rw-gold">Taller de itinerarios</p>
        <h2 data-i18n="planner.title" class="text-balance mt-3 font-display text-4xl font-black leading-[0.98] tracking-[-0.025em] text-rw-white dark:text-rw-white sm:text-6xl">
          Dime desde dónde sales. El mapa responde.
        </h2>
        <p data-i18n="planner.copy" class="text-pretty mt-5 font-body text-xl leading-relaxed text-rw-sand/75">
          Escribe tu ciudad, ajusta el viaje y abre cada destino para ver ruta, paradas, zonas donde dormir y enlaces útiles. Sin pantallas vacías ni recomendaciones sin contexto.
        </p>

        <form class="rw-planner-card mt-7 space-y-5" id="rw-trip-form">
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="rw-field sm:col-span-2">Vivo en
              <input id="rw-origin" list="rw-origin-cities" value="Barcelona" autocomplete="off" placeholder="Escribe tu ciudad: Madrid, Sevilla, Vigo..." />
              <datalist id="rw-origin-cities">
                {originCities.map((city) => <option value={city.name} />)}
              </datalist>
            </label>
            <button id="rw-location" class="rw-location-button sm:col-span-2" type="button">
              Usar mi ubicación actual para calcular distancias reales
            </button>
            <label class="rw-field">Interés principal
              <select id="rw-interest">
                <option value="naturaleza">Naturaleza</option>
                <option value="cultura">Cultura</option>
                <option value="playa">Playa</option>
                <option value="gastronomia">Comer bien</option>
                <option value="raro">Lugares raros</option>
                <option value="barato">Ahorrar</option>
                <option value="familia">Fácil en familia</option>
              </select>
            </label>
            <label class="rw-field">Temporada
              <select id="rw-season">
                <option value="primavera">Primavera</option>
                <option value="verano">Verano</option>
                <option value="otono">Otoño</option>
                <option value="invierno">Invierno</option>
              </select>
            </label>
            <label class="rw-field">Días libres
              <input id="rw-days" type="number" min="2" max="21" value="5" />
            </label>
            <label class="rw-field">Con quién vas
              <select id="rw-companion">
                <option value="pareja">Pareja</option>
                <option value="solo">Solo</option>
                <option value="amigos">Amigos</option>
                <option value="familia">Familia</option>
              </select>
            </label>
          </div>

          <div>
            <p class="rw-label">Transporte preferido</p>
            <div class="mt-2 grid grid-cols-3 gap-2 sm:grid-cols-5" role="group" aria-label="Tipo de transporte">
              <button class="rw-chip is-active" type="button" data-filter="transport" data-value="avion">Avión</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="coche">Coche</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="tren">Tren</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="ferry">Ferry</button>
              <button class="rw-chip" type="button" data-filter="transport" data-value="bus">Bus</button>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <p class="rw-label">Presupuesto</p>
              <div class="mt-2 grid grid-cols-3 gap-2" role="group" aria-label="Presupuesto">
                <button class="rw-chip" type="button" data-filter="budget" data-value="bajo">Bajo</button>
                <button class="rw-chip is-active" type="button" data-filter="budget" data-value="medio">Medio</button>
                <button class="rw-chip" type="button" data-filter="budget" data-value="alto">Alto</button>
              </div>
            </div>
            <div>
              <p class="rw-label">Ritmo</p>
              <div class="mt-2 grid grid-cols-3 gap-2" role="group" aria-label="Ritmo">
                <button class="rw-chip" type="button" data-filter="pace" data-value="rapido">Rápido</button>
                <button class="rw-chip is-active" type="button" data-filter="pace" data-value="equilibrado">Medio</button>
                <button class="rw-chip" type="button" data-filter="pace" data-value="lento">Lento</button>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-4 gap-3 border-t border-rw-ink/10 pt-4 font-ui text-center text-xs text-rw-ocean/75">
            <div><strong id="rw-count" class="block text-2xl text-rw-horizon">8</strong>rutas</div>
            <div><strong class="block text-2xl text-rw-forest">{totalDestinations}</strong>destinos</div>
            <div><strong class="block text-2xl text-rw-gold">{totalPlaces}</strong>lugares</div>
            <div><strong class="block text-2xl text-rw-ocean dark:text-rw-ink">{totalOrigins}</strong>salidas</div>
          </div>
        </form>
      </div>

      <div>
        <div id="rw-brief" class="mb-5 border-y border-rw-gold/20 bg-rw-sand/8 px-5 py-4 font-ui text-sm leading-relaxed text-rw-sand/76 backdrop-blur"></div>
        <div id="rw-results" class="grid gap-6"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .rw-planner-card {
    border: 1px solid rgba(198, 154, 84, .2);
    border-radius: 18px;
    background:
      linear-gradient(135deg, rgba(245,244,238,.94), rgba(231,229,218,.82)),
      radial-gradient(circle at 0 0, rgba(198,154,84,.16), transparent 38%);
    box-shadow: 0 30px 90px -70px rgba(0,0,0,.95);
    padding: clamp(18px, 3vw, 26px);
  }
  .rw-label, .rw-field { font: 900 11px/1.2 "JetBrains Mono", monospace; letter-spacing: .04em; text-transform: none; color: rgba(38, 58, 52, .72); }
  .dark .rw-label, .dark .rw-field { color: var(--rw-ocean); }
  .rw-field { display: grid; gap: 8px; }
  .rw-field input, .rw-field select { width: 100%; min-height: 48px; border-radius: 12px; border: 1px solid rgba(24,35,31,.16); background: rgba(251,250,244,.86); padding: 13px 15px; font: 700 14px/1.4 "DM Sans", sans-serif; color: var(--rw-ink); outline: none; transition: border-color 180ms ease, box-shadow 180ms ease, background 180ms ease; }
  .rw-field input:focus, .rw-field select:focus { border-color: var(--rw-horizon); background: var(--rw-white); box-shadow: 0 0 0 4px rgba(163,79,63,.12); }
  .rw-location-button { border: 1px solid rgba(177,95,62,.26); border-radius: 12px; background: rgba(177,95,62,.08); padding: 14px 16px; text-align: left; font: 900 13px/1.35 "DM Sans", sans-serif; color: var(--rw-horizon); transition: transform 180ms ease, border-color 180ms ease, background 180ms ease, color 180ms ease; }
  .rw-location-button:hover { transform: translateY(-1px); border-color: var(--rw-horizon); background: var(--rw-horizon); color: var(--rw-white); }
  .rw-chip { min-height: 44px; border-radius: 10px; border: 1px solid rgba(24,35,31,.16); font: 900 11px/1.1 "JetBrains Mono", monospace; color: var(--rw-ocean); background: rgba(251,250,244,.68); transition: transform 180ms ease, border-color 180ms ease, background 180ms ease, color 180ms ease, box-shadow 180ms ease; }
  .rw-chip:hover, .rw-chip.is-active { transform: translateY(-1px); border-color: rgba(177,95,62,.72); background: var(--rw-ink); color: var(--rw-white); box-shadow: 0 12px 34px -24px rgba(24,35,31,.95); }
  .rw-result-card { overflow: hidden; border: 1px solid rgba(198,154,84,.2); border-radius: 18px; background: #f8f5eb; box-shadow: 0 28px 85px -68px rgba(0,0,0,.95); transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease; }
  .rw-result-card:hover { transform: translateY(-2px); border-color: rgba(198,154,84,.4); box-shadow: 0 34px 95px -64px rgba(0,0,0,1); }
  .dark .rw-result-card { background: rgba(245,244,238,.94); }
  .rw-result-shell { display: grid; gap: 0; background: #f8f5eb; }
  .rw-result-art { width: 100%; height: 18rem; object-fit: cover; background: #e7e3d6; }
  .rw-result-body { background: rgba(251,250,244,.98); color: var(--rw-ink); padding: 1.25rem; }
  @media (min-width: 768px) {
    .rw-result-shell { grid-template-columns: minmax(220px, .9fr) minmax(0, 1.1fr); }
    .rw-result-art { height: 100%; min-height: 340px; }
    .rw-result-body { padding: 1.5rem; }
  }
  .rw-route-atlas { display: grid; grid-template-columns: 1.1fr .9fr; gap: 12px; border: 1px solid rgba(24,35,31,.12); background: rgba(248,245,235,.86); padding: 10px; }
  .rw-route-atlas img { width: 100%; height: 100%; min-height: 244px; border-radius: 14px; object-fit: cover; background: #f8f5eb; }
  .rw-route-atlas__notes { display: grid; align-content: center; gap: 12px; border-left: 1px solid rgba(24,35,31,.12); padding: 16px; }
  .rw-route-atlas__label { font: 900 11px/1.2 "JetBrains Mono", monospace; letter-spacing: .04em; color: var(--rw-horizon); }
  @media (max-width: 640px) { .rw-route-atlas { grid-template-columns: 1fr; } .rw-route-atlas__notes { border-left: 0; border-top: 1px solid rgba(24,35,31,.12); } }
</style>

<style is:global>
  #planificador-rutas .rw-result-card {
    overflow: hidden;
    border: 1px solid rgba(198, 154, 84, .24);
    border-radius: 18px;
    background: #f8f5eb;
    box-shadow: 0 28px 85px -68px rgba(0, 0, 0, .95);
    transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
  }
  #planificador-rutas .rw-result-card:hover {
    transform: translateY(-2px);
    border-color: rgba(198, 154, 84, .44);
    box-shadow: 0 34px 95px -64px rgba(0, 0, 0, 1);
  }
  #planificador-rutas .rw-result-shell {
    display: grid;
    gap: 0;
    background: #f8f5eb;
  }
  #planificador-rutas .rw-result-art {
    width: 100%;
    height: 18rem;
    object-fit: cover;
    background: #e7e3d6;
  }
  #planificador-rutas .rw-result-body {
    background: rgba(251, 250, 244, .98);
    color: var(--rw-ink);
    padding: 1.25rem;
  }
  #planificador-rutas .rw-route-atlas {
    display: grid;
    grid-template-columns: 1.1fr .9fr;
    gap: 12px;
    border: 1px solid rgba(24, 35, 31, .12);
    background: rgba(248, 245, 235, .86);
    padding: 10px;
  }
  #planificador-rutas .rw-route-atlas img {
    width: 100%;
    height: 100%;
    min-height: 244px;
    border-radius: 14px;
    object-fit: cover;
    background: #f8f5eb;
  }
  #planificador-rutas .rw-route-atlas__notes {
    display: grid;
    align-content: center;
    gap: 12px;
    border-left: 1px solid rgba(24, 35, 31, .12);
    padding: 16px;
  }
  #planificador-rutas .rw-route-atlas__label {
    font: 900 11px/1.2 "JetBrains Mono", monospace;
    letter-spacing: .04em;
    color: var(--rw-horizon);
  }
  @media (min-width: 768px) {
    #planificador-rutas .rw-result-shell {
      grid-template-columns: minmax(220px, .9fr) minmax(0, 1.1fr);
    }
    #planificador-rutas .rw-result-art {
      height: 100%;
      min-height: 340px;
    }
    #planificador-rutas .rw-result-body {
      padding: 1.5rem;
    }
  }
  @media (max-width: 640px) {
    #planificador-rutas .rw-route-atlas {
      grid-template-columns: 1fr;
    }
    #planificador-rutas .rw-route-atlas__notes {
      border-left: 0;
      border-top: 1px solid rgba(24, 35, 31, .12);
    }
  }
</style>

<script define:vars={{ routeDestinations: plannerDestinations, originCities }}>
  function setupRoutePlanner() {
    const root = document.getElementById('planificador-rutas');
    if (!root || root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';

    const results = root.querySelector('#rw-results');
    const count = root.querySelector('#rw-count');
    const brief = root.querySelector('#rw-brief');
    const state = {
      origin: 'Barcelona',
      interest: 'naturaleza',
      transport: 'avion',
      budget: 'medio',
      pace: 'equilibrado',
      season: 'primavera',
      days: 5,
      companion: 'pareja',
      originCoords: null,
    };

    function setTrustedHTML(element, html) {
      if (!element) return;
      window.__rwTrustedPolicies = window.__rwTrustedPolicies || {};
      if (window.trustedTypes && !window.__rwTrustedPolicies.routePlanner) {
        try {
          window.__rwTrustedPolicies.routePlanner = window.trustedTypes.createPolicy('routewonder-route-planner', {
            createHTML: (value) => value,
          });
        } catch {
          window.__rwTrustedPolicies.routePlanner = null;
        }
      }
      const policy = window.__rwTrustedPolicies.routePlanner;
      element.innerHTML = policy ? policy.createHTML(html) : html;
    }

    function normalize(value) {
      return String(value || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
    }

    function resolveOrigin(value) {
      if (state.originCoords) return state.originCoords;
      const needle = normalize(value);
      return originCities.find((city) => normalize(city.name) === needle)
        || originCities.find((city) => normalize(city.name).includes(needle) || needle.includes(normalize(city.name)))
        || null;
    }

    function distanceKm(a, b) {
      if (!a || !b) return null;
      const toRad = (n) => n * Math.PI / 180;
      const R = 6371;
      const dLat = toRad(Number(b.lat) - Number(a.lat));
      const dLng = toRad(Number(b.lng) - Number(a.lng));
      const lat1 = toRad(Number(a.lat));
      const lat2 = toRad(Number(b.lat));
      const h = Math.sin(dLat / 2) ** 2 + Math.cos(lat1) * Math.cos(lat2) * Math.sin(dLng / 2) ** 2;
      return Math.round(2 * R * Math.asin(Math.sqrt(h)));
    }

    function scoreDestination(item, origin) {
      let score = 0;
      if (item.interests.includes(state.interest)) score += 34;
      if (item.transport.includes(state.transport)) score += 26;
      if (item.budget === state.budget) score += 15;
      if (item.seasons.includes(state.season)) score += 14;
      const distance = distanceKm(origin, item);
      if (distance !== null) {
        if (state.transport === 'coche') score += distance < 900 ? 18 : distance < 1500 ? 8 : -12;
        if (state.transport === 'tren') score += distance < 1100 ? 16 : -8;
        if (state.transport === 'avion') score += distance > 500 ? 12 : 4;
        if (state.transport === 'bus') score += distance < 800 ? 12 : -6;
      }
      const wantedDays = Number(state.days || 5);
      const itemDays = Number(String(item.days).match(/\d+/)?.[0] || 5);
      score += Math.max(0, 12 - Math.abs(wantedDays - itemDays) * 3);
      if (state.companion === 'familia' && item.interests.includes('familia')) score += 10;
      if (state.pace === 'lento' && itemDays >= 5) score += 7;
      if (state.pace === 'rapido' && itemDays <= 3) score += 7;
      return score;
    }

    function matchesVisibleSeason(item) {
      const selected = normalize(state.season);
      const text = normalize(`${item.name} ${item.description || ''} ${(item.tags || []).join(' ')}`);
      const conflicts = {
        primavera: ['invierno'],
        verano: ['invierno'],
        otono: ['verano pleno', 'agosto'],
        invierno: ['verano'],
      };
      return !(conflicts[selected] || []).some((word) => text.includes(word));
    }

    function modeLabel(item, distance) {
      const direct = item.transport.includes(state.transport) ? state.transport : item.transport[0];
      const km = distance === null ? 'distancia según salida' : `${distance.toLocaleString('es-ES')} km aprox.`;
      if (direct === 'coche') return `Coche · ${km}`;
      if (direct === 'tren') return `Tren · ${km}`;
      if (direct === 'ferry') return `Avión + ferry · ${km}`;
      if (direct === 'bus') return `Avión/bus · ${km}`;
      return `Avión · ${km}`;
    }

    function itinerary(item) {
      const total = Math.min(7, Math.max(2, Number(state.days || 5)));
      const stops = item.highlights;
      return Array.from({ length: total }, (_, index) => {
        const stop = stops[index % stops.length];
        if (index === 0) return `Día 1: llegada tranquila y paseo por ${stop}.`;
        if (index === total - 1) return `Día ${index + 1}: mañana libre y regreso sin apurar.`;
        return `Día ${index + 1}: ${stop}, comida local y una parada secundaria.`;
      });
    }

    function renderDetails(item) {
      const detailPhoto = item.photos[1] || item.photos[0];
      return `
        <div class="mt-5 border-t border-rw-mist/20 pt-5">
          <div class="rw-route-atlas overflow-hidden rounded-2xl">
            <img src="${detailPhoto}" alt="Lámina de detalle de ${item.name}" loading="eager">
            <div class="rw-route-atlas__notes">
              <span class="rw-route-atlas__label">Atlas editorial</span>
              <p class="font-display text-2xl font-black leading-tight text-rw-ink">${item.name}</p>
              <p class="font-ui text-sm leading-relaxed text-rw-ocean/76">Lámina editorial con el ritmo del viaje, las paradas principales y el tipo de paisaje que vas a encontrar.</p>
              <div class="flex flex-wrap gap-2">
                ${item.transport.map((mode) => `<span class="rounded-full border border-rw-ink/10 px-3 py-1 font-mono text-xs font-bold text-rw-ocean">${mode}</span>`).join('')}
              </div>
            </div>
          </div>
          <div class="mt-5 grid gap-4 md:grid-cols-2">
            <div class="rounded-[1.35rem] border border-rw-ink/10 bg-rw-sand/70 p-4">
              <h4 class="font-display text-xl font-bold text-rw-ink">Ruta sugerida</h4>
              <ol class="mt-3 grid gap-2 font-ui text-sm text-rw-ocean/80">${itinerary(item).map((step) => `<li>${step}</li>`).join('')}</ol>
            </div>
            <div class="rounded-[1.35rem] border border-rw-ink/10 bg-rw-sand/70 p-4">
              <h4 class="font-display text-xl font-bold text-rw-ink">Qué mirar antes de reservar</h4>
              <ul class="mt-3 grid gap-2 font-ui text-sm text-rw-ocean/80">
                <li><strong>Visitas:</strong> ${item.highlights.join(', ')}.</li>
                <li><strong>Comer:</strong> ${item.food.join(', ')}.</li>
                <li><strong>Dormir:</strong> ${item.stay.join(' · ')}.</li>
              </ul>
            </div>
          </div>
          <div class="mt-4 flex flex-wrap gap-3">
            <a class="rounded-full bg-rw-ink px-4 py-2 font-ui text-xs font-black uppercase tracking-wider text-white transition hover:bg-rw-horizon" href="${item.article}">Guía completa</a>
            <a class="rounded-full border border-rw-horizon/30 px-4 py-2 font-ui text-xs font-black uppercase tracking-wider text-rw-horizon transition hover:border-rw-horizon hover:bg-rw-horizon hover:text-white" href="${item.mapUrl}" target="_blank" rel="noopener noreferrer">Mapa</a>
            <a class="rounded-full border border-rw-horizon/30 px-4 py-2 font-ui text-xs font-black uppercase tracking-wider text-rw-horizon transition hover:border-rw-horizon hover:bg-rw-horizon hover:text-white" href="${item.hotelUrl}" target="_blank" rel="nofollow sponsored noopener noreferrer">Hoteles</a>
            <a class="rounded-full border border-rw-horizon/30 px-4 py-2 font-ui text-xs font-black uppercase tracking-wider text-rw-horizon transition hover:border-rw-horizon hover:bg-rw-horizon hover:text-white" href="${item.restaurantUrl}" target="_blank" rel="noopener noreferrer">Restaurantes</a>
            <a class="rounded-full border border-rw-horizon/30 px-4 py-2 font-ui text-xs font-black uppercase tracking-wider text-rw-horizon transition hover:border-rw-horizon hover:bg-rw-horizon hover:text-white" href="${item.activityUrl}" target="_blank" rel="nofollow sponsored noopener noreferrer">Actividades</a>
          </div>
        </div>`;
    }

    function render() {
      const origin = resolveOrigin(state.origin);
      const candidates = routeDestinations.filter(matchesVisibleSeason);
      const strict = candidates.filter((item) =>
        item.seasons.includes(state.season)
        && item.interests.includes(state.interest)
        && item.transport.includes(state.transport)
      );
      const seasonal = candidates.filter((item) =>
        item.seasons.includes(state.season)
        && item.interests.includes(state.interest)
      );
      const pool = strict.length ? strict : seasonal.length ? seasonal : candidates.filter((item) => item.seasons.includes(state.season));
      const ranked = pool
        .map((item) => {
          const distance = distanceKm(origin, item);
          return { ...item, distance, score: scoreDestination(item, origin) };
        })
        .sort((a, b) => b.score - a.score)
        .slice(0, 8);

      count.textContent = String(ranked.length);
      brief.replaceChildren();
      const briefStrong = document.createElement('strong');
      briefStrong.textContent = 'Salida:';
      const briefText = document.createTextNode(origin
        ? ` ${origin.name}. ${strict.length ? 'Coincidencias exactas' : 'Alternativas cercanas'} para ${state.season}, ${state.interest}, ${state.transport}, ${state.days} días y presupuesto ${state.budget}.`
        : ` ${state.origin}. No tengo coordenadas exactas de esa ciudad todavía, así que ordeno por estilo de viaje y logística.`);
      brief.append(briefStrong, briefText);

      results.replaceChildren();
      ranked.forEach((item, index) => {
        const article = document.createElement('article');
        article.className = 'rw-result-card';
        setTrustedHTML(article, `
          <div class="rw-result-shell">
            <img src="${item.photos[0]}" alt="Lámina de ruta de ${item.name}" loading="eager" class="rw-result-art">
            <div class="rw-result-body">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="font-ui text-xs font-black uppercase tracking-[0.16em] text-rw-horizon">${item.country} · ${item.days}</p>
                  <h3 class="mt-1 font-display text-3xl font-black leading-tight tracking-[-0.015em] text-rw-ink dark:text-rw-ink">${item.name}</h3>
                </div>
                <span class="rounded-full border border-rw-ink/10 bg-rw-sand px-3 py-1 font-mono text-xs font-bold text-rw-horizon">#${index + 1}</span>
              </div>
              <p class="mt-3 font-ui text-sm leading-relaxed text-rw-ocean/75 dark:text-rw-ocean/75">${item.description || `${modeLabel(item, item.distance)}. Encaja por ${item.interests.slice(0, 3).join(', ')}.`}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                ${item.highlights.slice(0, 3).map((tag) => `<span class="rounded-full border border-rw-ink/10 bg-rw-gold/12 px-3 py-1 font-ui text-xs font-bold text-rw-ocean dark:text-rw-ocean">${tag}</span>`).join('')}
              </div>
              <button class="mt-5 rounded-full bg-rw-ink px-5 py-3 font-ui text-xs font-black uppercase tracking-wider text-white transition hover:-translate-y-0.5 hover:bg-rw-horizon focus:outline-none focus-visible:ring-2 focus-visible:ring-rw-horizon focus-visible:ring-offset-2" type="button" data-detail="${item.id}" aria-expanded="false">
                Ver ruta y detalles
              </button>
              <div class="hidden" data-panel="${item.id}">${renderDetails(item)}</div>
            </div>
          </div>`);
        results.appendChild(article);
      });

      results.querySelectorAll('[data-detail]').forEach((button) => {
        button.addEventListener('click', () => {
          const panel = results.querySelector(`[data-panel="${button.dataset.detail}"]`);
          if (!panel) return;
          panel.classList.toggle('hidden');
          const isHidden = panel.classList.contains('hidden');
          button.textContent = isHidden ? 'Ver ruta y detalles' : 'Ocultar detalles';
          button.setAttribute('aria-expanded', String(!isHidden));
        });
      });
    }

    root.querySelectorAll('.rw-chip').forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter;
        state[filter] = button.dataset.value;
        root.querySelectorAll(`[data-filter="${filter}"]`).forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');
        render();
      });
    });

    const boundFields = {
      origin: '#rw-origin',
      interest: '#rw-interest',
      season: '#rw-season',
      days: '#rw-days',
      companion: '#rw-companion',
    };
    Object.entries(boundFields).forEach(([key, selector]) => {
      const input = root.querySelector(selector);
      if (!input) return;
      input.addEventListener('input', () => { state[key] = input.value; if (key === 'origin') state.originCoords = null; render(); });
      input.addEventListener('change', () => { state[key] = input.value; if (key === 'origin') state.originCoords = null; render(); });
    });

    const locationButton = root.querySelector('#rw-location');
    if (locationButton) {
      locationButton.addEventListener('click', () => {
        if (!navigator.geolocation) {
          locationButton.textContent = 'Tu navegador no permite ubicación. Escribe tu ciudad arriba.';
          return;
        }
        locationButton.textContent = 'Calculando desde tu ubicación...';
        navigator.geolocation.getCurrentPosition((position) => {
          state.origin = 'tu ubicación actual';
          state.originCoords = {
            name: 'tu ubicación actual',
            lat: position.coords.latitude,
            lng: position.coords.longitude,
          };
          const originInput = root.querySelector('#rw-origin');
          if (originInput) originInput.value = 'Ubicación actual';
          locationButton.textContent = 'Usando tu ubicación actual';
          render();
        }, () => {
          locationButton.textContent = 'No se pudo usar la ubicación. Escribe tu ciudad arriba.';
        }, { enableHighAccuracy: false, timeout: 8000, maximumAge: 900000 });
      });
    }

    render();
  }

  setupRoutePlanner();
  document.addEventListener('astro:after-swap', setupRoutePlanner);
</script>
