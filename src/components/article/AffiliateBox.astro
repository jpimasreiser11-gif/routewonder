---
export interface Props {
  type: "accommodation" | "car" | "activities" | "esim";
  destination: string;
}

const { type, destination } = Astro.props;

const configs = {
  accommodation: {
    label: "Dormir",
    title: `Alojamiento en ${destination}`,
    text: "Compara zonas y precios antes de cerrar la ruta. En destinos pequeños conviene mirar disponibilidad pronto.",
    cta: "Ver hoteles",
    url: `https://www.booking.com/searchresults.html?ss=${encodeURIComponent(destination)}`,
  },
  car: {
    label: "Coche",
    title: "Alquiler para esta ruta",
    text: "Útil si la guía depende de miradores, pueblos secundarios o paradas donde el transporte público llega mal.",
    cta: "Comparar coche",
    url: "https://www.rentalcars.com/",
  },
  activities: {
    label: "Planes",
    title: `Actividades en ${destination}`,
    text: "Tours pequeños, entradas y excursiones que pueden ahorrar colas si viajas en temporada alta.",
    cta: "Ver actividades",
    url: `https://www.getyourguide.com/s/?q=${encodeURIComponent(destination)}`,
  },
  esim: {
    label: "Datos",
    title: "Internet durante el viaje",
    text: "Una eSIM evita depender de WiFi de hotel cuando usas mapas, reservas o traducción en ruta.",
    cta: "Ver eSIM",
    url: "https://www.airalo.com/",
  },
};

const config = configs[type];
---

<aside class="my-8 rounded-2xl border border-rw-horizon/18 bg-rw-sand/75 p-5 shadow-sm dark:border-rw-horizon/30 dark:bg-rw-ocean/45">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <span class="font-ui text-[0.68rem] font-black uppercase tracking-[0.2em] text-rw-horizon">{config.label}</span>
      <h3 class="mt-1 font-display text-2xl font-bold text-rw-ink dark:text-rw-white">{config.title}</h3>
      <p class="mt-2 font-ui text-sm leading-relaxed text-rw-ocean/72 dark:text-rw-mist">{config.text}</p>
    </div>
    <a
      href={config.url}
      target="_blank"
      rel="nofollow sponsored noopener noreferrer"
      class="inline-flex shrink-0 justify-center rounded-full bg-rw-horizon px-5 py-3 font-ui text-xs font-black uppercase tracking-[0.14em] text-white transition hover:-translate-y-0.5 hover:bg-rw-ink"
    >
      {config.cta}
    </a>
  </div>
  <p class="mt-3 font-ui text-[0.72rem] leading-relaxed text-rw-ocean/55 dark:text-rw-mist/70">
    Enlace de afiliado: podemos recibir una comisión sin coste extra para ti. La recomendación editorial sigue siendo independiente.
  </p>
</aside>
