---
import { getCollection } from "astro:content";
import { getContentSlug } from "../../lib/contentSlug";

export interface Props {
  currentSlug: string;
  category: string;
  tags?: string[];
}

const { currentSlug, category, tags = [] } = Astro.props;
const posts = await getCollection("blog", ({ data }) => !data.draft);

const related = posts
  .filter((post) => getContentSlug(post) !== currentSlug)
  .map((post) => {
    const tagScore = (post.data.tags ?? []).filter((tag) => tags.includes(tag)).length;
    const categoryScore = post.data.category === category ? 3 : 0;
    return { post, score: categoryScore + tagScore };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score || Number(b.post.data.publishedDate) - Number(a.post.data.publishedDate))
  .slice(0, 3);
---

{related.length > 0 && (
  <section class="mt-14 border-t border-rw-mist/20 pt-10">
    <p class="font-ui text-xs font-black uppercase tracking-[0.22em] text-rw-horizon">Sigue la ruta</p>
    <h2 class="mt-2 font-display text-3xl font-black text-rw-ink dark:text-rw-white">También te puede interesar</h2>
    <div class="mt-6 grid gap-5 md:grid-cols-3">
      {related.map(({ post }) => {
        const slug = getContentSlug(post);
        return (
        <a href={`/blog/${slug}/`} class="group overflow-hidden rounded-2xl border border-rw-mist/18 bg-rw-white shadow-sm transition hover:-translate-y-1 hover:border-rw-horizon/40 dark:bg-rw-ocean/40">
          {post.data.image && (
            <img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} loading="lazy" class="h-40 w-full object-cover transition duration-500 group-hover:scale-105" />
          )}
          <div class="p-4">
            <span class="font-ui text-[0.65rem] font-black uppercase tracking-[0.18em] text-rw-forest">{post.data.category.replaceAll("-", " ")}</span>
            <h3 class="mt-2 font-display text-xl font-bold leading-tight text-rw-ink group-hover:text-rw-horizon dark:text-rw-white">{post.data.title}</h3>
            <p class="mt-2 font-ui text-xs text-rw-ocean/58 dark:text-rw-mist">{post.data.readingTime ?? 7} min de lectura</p>
          </div>
        </a>
        );
      })}
    </div>
  </section>
)}
