---
import type { CollectionEntry } from "astro:content";
import Badge from "../ui/Badge.astro";
import { getContentSlug } from "../../lib/contentSlug";

export interface Props {
  post: CollectionEntry<"blog">;
  class?: string;
}

const { post, class: className = "" } = Astro.props;
const { title, description, publishedDate, author, category, image, imageAlt, readingTime } = post.data;
const slug = getContentSlug(post);

const formattedDate = new Date(publishedDate).toLocaleDateString("es-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<article class={`group flex flex-col overflow-hidden rounded-[1.35rem] border border-rw-ink/10 bg-rw-white/72 transition duration-300 hover:-translate-y-1 hover:border-rw-horizon/32 hover:bg-rw-white hover:shadow-[0_26px_80px_-62px_rgba(33,29,25,.9)] ${className}`}>
  <!-- Article Image -->
  <a href={`${base}blog/${slug}/`} class="relative block overflow-hidden aspect-[4/3] bg-rw-sand select-none" aria-label={`Leer artículo: ${title}`}>
    {
      image ? (
        <img
          src={image}
          alt={imageAlt || ""}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.035]"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-rw-mist/40 bg-gradient-to-br from-rw-sand to-rw-white dark:from-rw-ink dark:to-rw-white/5">
          <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
        </div>
      )
    }
    
    <!-- Float category badge -->
    <div class="absolute left-3 top-3 z-10 pointer-events-none">
      <Badge category={category} linked={false} />
    </div>
  </a>

  <!-- Article Info -->
  <div class="flex flex-grow flex-col p-5 md:p-6">
    <!-- Meta Info -->
    <div class="mb-3 flex items-center gap-3 border-b border-rw-ink/10 pb-3 font-ui text-[11px] font-black uppercase tracking-[0.14em] text-rw-mist">
      <time datetime={publishedDate.toISOString()}>{formattedDate}</time>
      {readingTime && <span>·</span> <span>{readingTime} min de lectura</span>}
    </div>

    <!-- Title -->
    <h3 class="mb-3 font-display text-2xl font-black leading-tight tracking-[-0.012em] text-rw-ink transition-colors group-hover:text-rw-horizon">
      <a href={`${base}blog/${slug}/`}>
        {title}
      </a>
    </h3>

    <!-- Excerpt -->
    <p class="mb-6 font-ui text-sm leading-relaxed text-rw-ocean/72 line-clamp-3">
      {description}
    </p>

    <!-- Footer Author info -->
    <div class="mt-auto flex items-center gap-3 border-t border-rw-ink/10 pt-4 select-none">
      <div class="flex h-8 w-8 items-center justify-center rounded-full border border-rw-horizon/25 bg-rw-horizon/10 font-display text-xs font-bold text-rw-horizon">
        {author.split(" ").map(n => n[0]).join("")}
      </div>
      <div class="font-ui text-xs">
        <p class="font-bold leading-none text-rw-ink">{author}</p>
        <p class="mt-0.5 text-[10px] uppercase tracking-wider text-rw-ocean/50">Explorador &amp; Autor</p>
      </div>
    </div>
  </div>
</article>
