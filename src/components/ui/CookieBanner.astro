---
---
<div
  id="cookie-banner"
  class="fixed bottom-3 left-3 right-3 md:left-auto md:right-4 md:max-w-sm z-50 bg-rw-ink/94 text-rw-sand border border-rw-gold/20 backdrop-blur-md p-4 rounded-[.9rem] shadow-[0_22px_70px_-42px_rgba(0,0,0,.95)] translate-y-24 opacity-0 transition-all duration-500 ease-out pointer-events-none"
  role="alert"
>
  <h3 class="font-display text-base font-bold text-rw-white mb-1">Privacidad</h3>
  <p class="font-ui text-xs text-rw-sand/78 mb-3 leading-relaxed">
    Cookies esenciales y analítica solo si aceptas. Puedes seguir explorando sin bloquear la web.
    <a href="/cookie-policy/" class="font-bold text-rw-horizon underline underline-offset-2">Política de cookies</a>.
  </p>
  <div class="grid grid-cols-2 gap-2">
    <button
      id="btn-cookies-essential"
      class="min-h-10 px-3 py-2 text-xs font-semibold font-ui text-rw-sand/80 hover:text-rw-white border border-rw-gold/20 rounded-lg transition-colors hover:bg-rw-white/8"
    >
      Solo esenciales
    </button>
    <button
      id="btn-cookies-accept"
      class="min-h-10 px-3 py-2 text-xs font-semibold font-ui text-rw-ink bg-rw-gold hover:bg-rw-gold/90 rounded-lg shadow-sm shadow-rw-gold/20 transition-all active:scale-95"
    >
      Aceptar todas
    </button>
  </div>
</div>

<script>
  function setupCookieBanner() {
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('btn-cookies-accept');
    const essentialBtn = document.getElementById('btn-cookies-essential');

    if (!banner || !acceptBtn || !essentialBtn) return;

    // Check if user has already made a choice
    const cookieChoice = localStorage.getItem('cookie-consent');

    if (!cookieChoice) {
      // Show the banner with a slight delay
      setTimeout(() => {
        banner.classList.remove('translate-y-24', 'opacity-0', 'pointer-events-none');
        banner.classList.add('translate-y-0', 'opacity-100');
      }, 1500);
    } else {
      banner.style.display = 'none';
    }

    const dismissBanner = (choice: string) => {
      localStorage.setItem('cookie-consent', choice);
      window.dispatchEvent(new CustomEvent('cookie-consent-updated', { detail: { choice } }));
      banner.classList.add('translate-y-24', 'opacity-0', 'pointer-events-none');
      banner.classList.remove('translate-y-0', 'opacity-100');
      setTimeout(() => {
        banner.style.display = 'none';
      }, 500);
    };

    acceptBtn.addEventListener('click', () => dismissBanner('all'));
    essentialBtn.addEventListener('click', () => dismissBanner('essential'));
  }

  // Run on initial load and view transitions
  setupCookieBanner();
  document.addEventListener('astro:after-swap', setupCookieBanner);
</script>
