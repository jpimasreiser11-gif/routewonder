---
import CategoryIcon from "./CategoryIcon.astro";

export interface Props {
  category: string;
  class?: string;
  linked?: boolean;
}

const { category, class: className = "", linked = true } = Astro.props;

const categoryMap: Record<string, { label: string; icon: string; color: string }> = {
  'rutas-sorprendentes': {
    label: 'Rutas Sorprendentes',
    icon: 'route',
    color: 'bg-rw-ocean/10 text-rw-ocean border-rw-ocean/20 dark:bg-rw-mist/10 dark:text-rw-mist dark:border-rw-mist/20'
  },
  'ciudades-extranas': {
    label: 'Ciudades Extrañas',
    icon: 'city',
    color: 'bg-rw-ink/10 text-rw-ink border-rw-ink/20 dark:bg-rw-sand/10 dark:text-rw-sand dark:border-rw-sand/20'
  },
  'destinos-secretos': {
    label: 'Destinos Secretos',
    icon: 'island',
    color: 'bg-rw-forest/10 text-rw-forest border-rw-forest/20 dark:bg-emerald-500/10 dark:text-emerald-400 dark:border-emerald-500/20'
  },
  'viaje-economico': {
    label: 'Viaje Económico',
    icon: 'budget',
    color: 'bg-rw-gold/10 text-rw-gold border-rw-gold/20 dark:bg-amber-500/10 dark:text-amber-400 dark:border-amber-500/20'
  },
  'curiosidades-geograficas': {
    label: 'Curiosidades Geográficas',
    icon: 'geo',
    color: 'bg-indigo-500/10 text-indigo-600 border-indigo-500/20 dark:bg-indigo-400/10 dark:text-indigo-300 dark:border-indigo-400/20'
  },
  'lugares-de-pelicula': {
    label: 'Lugares de Película',
    icon: 'cinema',
    color: 'bg-rw-horizon/10 text-rw-horizon border-rw-horizon/20 dark:bg-rw-horizon/20 dark:text-rw-horizon dark:border-rw-horizon/30'
  },
  'viaje-rapido': {
    label: 'Viaje Rápido',
    icon: 'fast',
    color: 'bg-yellow-500/10 text-yellow-700 border-yellow-500/20 dark:bg-yellow-500/10 dark:text-yellow-400 dark:border-yellow-500/20'
  }
};

const categoryInfo = categoryMap[category] || {
  label: category,
  icon: 'route',
  color: 'bg-rw-mist/10 text-rw-ink border-rw-mist/20 dark:text-rw-sand'
};

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const badgeClass = `inline-flex items-center gap-1.5 px-3 py-1 text-xs font-semibold font-ui rounded-full border transition-all duration-200 leading-tight ${linked ? "hover:scale-105" : ""} ${categoryInfo.color} ${className}`;
---

{
  linked ? (
    <a href={`${base}categoria/${category}/`} class={badgeClass}>
      <CategoryIcon icon={categoryInfo.icon} class="w-3.5 h-3.5 shrink-0" />
      <span>{categoryInfo.label}</span>
    </a>
  ) : (
    <span class={badgeClass}>
      <CategoryIcon icon={categoryInfo.icon} class="w-3.5 h-3.5 shrink-0" />
      <span>{categoryInfo.label}</span>
    </span>
  )
}
