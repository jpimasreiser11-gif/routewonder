---
const placeholder = Astro.props.placeholder || "Buscar rutas, ciudades o curiosidades...";
const placeholderKey = Astro.props.placeholderKey || "search.placeholder";
---

<div class="relative w-full max-w-2xl" data-search-root>
  <label class="sr-only" for="site-search">Buscar en RouteWonder</label>
  <input
    id="site-search"
    data-search-input
    data-i18n-placeholder={placeholderKey}
    type="search"
    placeholder={placeholder}
    autocomplete="off"
    class="w-full rounded-[1.1rem] border border-rw-ink/10 bg-rw-white/92 px-5 py-4 pr-12 font-ui text-sm font-semibold text-rw-ink outline-none transition placeholder:text-rw-mist focus:border-rw-horizon focus:bg-rw-white focus:ring-4 focus:ring-rw-horizon/14"
  />
  <button
    type="button"
    data-search-submit
    class="absolute right-2 top-1/2 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-[.8rem] text-rw-horizon transition hover:bg-rw-horizon/10 hover:text-rw-ink focus:outline-none focus:ring-2 focus:ring-rw-horizon/35"
    aria-label="Buscar en RouteWonder"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="m21 21-4.3-4.3m1.3-5.2a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
    </svg>
  </button>
  <div
    data-search-results
    class="absolute left-0 right-0 top-full z-50 mt-3 hidden max-h-80 overflow-auto rounded-[1.2rem] border border-rw-ink/10 bg-rw-white p-3 text-left shadow-[0_28px_90px_-55px_rgba(33,29,25,.85)]"
  ></div>
</div>

<script>
  function setupRouteWonderSearch() {
    const roots = document.querySelectorAll('[data-search-root]');
    roots.forEach((root) => {
      const input = root.querySelector('[data-search-input]');
      const results = root.querySelector('[data-search-results]');
      const submit = root.querySelector('[data-search-submit]');
      if (!input || !results || input.dataset.ready === 'true') return;
      input.dataset.ready = 'true';

      let pagefindPromise;
      const loadPagefind = () => {
        if (!pagefindPromise) {
          const runtimeModule = '/pagefind/' + 'pagefind.js';
          pagefindPromise = import(/* @vite-ignore */ runtimeModule);
        }
        return pagefindPromise;
      };

      const clearResults = () => results.replaceChildren();
      const canLoadPagefind = !import.meta.env.DEV;

      const appendLink = ({ href, title, excerpt, className = 'block rounded-xl px-3 py-3 transition hover:bg-rw-sand/70' }) => {
        const link = document.createElement('a');
        link.className = className;
        link.href = href;
        const titleEl = document.createElement('span');
        titleEl.className = 'block font-ui text-sm font-bold text-rw-ink';
        titleEl.textContent = title;
        link.appendChild(titleEl);
        if (excerpt) {
          const excerptEl = document.createElement('span');
          excerptEl.className = 'mt-1 block font-ui text-xs text-rw-ocean/70';
          excerptEl.textContent = excerpt;
          link.appendChild(excerptEl);
        }
        results.appendChild(link);
      };

      const appendMessage = (message) => {
        const p = document.createElement('p');
        p.className = 'rounded-xl border border-rw-ink/10 bg-rw-sand/55 px-3 py-3 font-ui text-sm text-rw-ocean/70';
        p.textContent = message;
        results.appendChild(p);
      };

      input.addEventListener('input', async () => {
        const query = input.value.trim();
        if (query.length < 2) {
          results.classList.add('hidden');
          clearResults();
          return;
        }

        if (!canLoadPagefind) {
          clearResults();
          appendLink({
            href: `/search/?query=${encodeURIComponent(query)}`,
            title: `Buscar "${query}" en el cuaderno`,
            className: 'block rounded-xl bg-rw-sand px-3 py-3 font-ui text-xs font-bold tracking-[0.04em] text-rw-horizon',
          });
          results.classList.remove('hidden');
          return;
        }

        try {
          const pagefind = await loadPagefind();
          const search = await pagefind.search(query);
          const top = await Promise.all(search.results.slice(0, 10).map((result) => result.data()));
          clearResults();
          if (top.length) {
            top.forEach((item) => appendLink({
              href: item.url,
              title: item.meta.title || item.url,
              excerpt: item.excerpt || '',
            }));
            appendLink({
              href: '/blog/',
              title: 'Ver todo el catálogo',
              className: 'mt-2 block rounded-xl bg-rw-sand px-3 py-3 font-ui text-xs font-bold uppercase tracking-wider text-rw-horizon',
            });
          } else {
            appendMessage('No encuentro esa ruta todavía. Prueba con país, ciudad, tren o playa.');
          }
          results.classList.remove('hidden');
        } catch {
          clearResults();
          appendLink({
            href: '/blog/',
            title: 'Abrir catálogo completo',
            className: 'block rounded-xl bg-rw-sand px-3 py-3 font-ui text-xs font-bold uppercase tracking-wider text-rw-horizon',
          });
          results.classList.remove('hidden');
        }
      });

      input.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' && input.value.trim().length > 1) {
          window.location.href = `/search/?query=${encodeURIComponent(input.value.trim())}`;
        }
      });
      submit?.addEventListener('click', () => {
        if (input.value.trim().length > 1) {
          window.location.href = `/search/?query=${encodeURIComponent(input.value.trim())}`;
        } else {
          input.focus();
        }
      });
    });
  }

  setupRouteWonderSearch();
  document.addEventListener('astro:after-swap', setupRouteWonderSearch);
</script>
