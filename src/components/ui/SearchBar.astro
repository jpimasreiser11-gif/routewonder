---
const placeholder = Astro.props.placeholder || "Buscar rutas, ciudades o curiosidades...";
---

<div class="relative w-full max-w-2xl" data-search-root>
  <label class="sr-only" for="site-search">Buscar en RouteWonder</label>
  <input
    id="site-search"
    data-search-input
    type="search"
    placeholder={placeholder}
    autocomplete="off"
    class="w-full rounded-2xl border border-rw-sand/25 bg-rw-white/95 px-5 py-4 pr-12 font-ui text-sm text-rw-ink shadow-2xl shadow-rw-ink/20 outline-none transition focus:border-rw-horizon focus:ring-4 focus:ring-rw-horizon/20"
  />
  <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-rw-horizon">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="m21 21-4.3-4.3m1.3-5.2a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
    </svg>
  </span>
  <div
    data-search-results
    class="absolute left-0 right-0 top-full z-50 mt-3 hidden max-h-80 overflow-auto rounded-2xl border border-rw-mist/25 bg-rw-white p-3 text-left shadow-2xl shadow-rw-ink/20"
  ></div>
</div>

<script>
  function setupRouteWonderSearch() {
    const roots = document.querySelectorAll('[data-search-root]');
    roots.forEach((root) => {
      const input = root.querySelector('[data-search-input]');
      const results = root.querySelector('[data-search-results]');
      if (!input || !results || input.dataset.ready === 'true') return;
      input.dataset.ready = 'true';

      let pagefindPromise;
      const loadPagefind = () => {
        if (!pagefindPromise) {
          const runtimeModule = '/pagefind/' + 'pagefind.js';
          pagefindPromise = import(/* @vite-ignore */ runtimeModule);
        }
        return pagefindPromise;
      };

      const clearResults = () => results.replaceChildren();

      const appendLink = ({ href, title, excerpt, className = 'block rounded-xl px-3 py-3 hover:bg-rw-sand/70' }) => {
        const link = document.createElement('a');
        link.className = className;
        link.href = href;
        const titleEl = document.createElement('span');
        titleEl.className = 'block font-ui text-sm font-bold text-rw-ink';
        titleEl.textContent = title;
        link.appendChild(titleEl);
        if (excerpt) {
          const excerptEl = document.createElement('span');
          excerptEl.className = 'mt-1 block font-ui text-xs text-rw-ocean/70';
          excerptEl.textContent = excerpt;
          link.appendChild(excerptEl);
        }
        results.appendChild(link);
      };

      const appendMessage = (message) => {
        const p = document.createElement('p');
        p.className = 'px-3 py-3 font-ui text-sm text-rw-ocean/70';
        p.textContent = message;
        results.appendChild(p);
      };

      input.addEventListener('input', async () => {
        const query = input.value.trim();
        if (query.length < 2) {
          results.classList.add('hidden');
          clearResults();
          return;
        }

        try {
          const pagefind = await loadPagefind();
          const search = await pagefind.search(query);
          const top = await Promise.all(search.results.slice(0, 10).map((result) => result.data()));
          clearResults();
          if (top.length) {
            top.forEach((item) => appendLink({
              href: item.url,
              title: item.meta.title || item.url,
              excerpt: item.excerpt || '',
            }));
            appendLink({
              href: '/blog/',
              title: 'Ver todo el catálogo',
              className: 'mt-2 block rounded-xl bg-rw-sand px-3 py-3 font-ui text-xs font-bold uppercase tracking-wider text-rw-horizon',
            });
          } else {
            appendMessage('No encuentro esa ruta todavía. Prueba con país, ciudad, tren o playa.');
          }
          results.classList.remove('hidden');
        } catch {
          clearResults();
          appendLink({
            href: '/blog/',
            title: 'Abrir catálogo completo',
            className: 'block rounded-xl bg-rw-sand px-3 py-3 font-ui text-xs font-bold uppercase tracking-wider text-rw-horizon',
          });
          results.classList.remove('hidden');
        }
      });

      input.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' && input.value.trim().length > 1) {
          window.location.href = `/blog/?q=${encodeURIComponent(input.value.trim())}`;
        }
      });
    });
  }

  setupRouteWonderSearch();
  document.addEventListener('astro:after-swap', setupRouteWonderSearch);
</script>
