---
export interface Props {
  label?: string;
}

const { label = "Lámina de ruta con relieve y paradas marcadas" } = Astro.props;
---

<div class="rw-web3d" role="img" aria-label={label}>
  <span class="rw-map-grid" aria-hidden="true"></span>
  <span class="rw-map-line rw-map-line-a" aria-hidden="true"></span>
  <span class="rw-map-line rw-map-line-b" aria-hidden="true"></span>
  <span class="rw-map-pin rw-map-pin-a" aria-hidden="true"></span>
  <span class="rw-map-pin rw-map-pin-b" aria-hidden="true"></span>
  <span class="rw-map-pin rw-map-pin-c" aria-hidden="true"></span>
</div>
