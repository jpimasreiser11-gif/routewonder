---
export interface Props {
  label?: string;
}

const { label = "Mapa abstracto en tres dimensiones" } = Astro.props;
---

<div class="rw-web3d" aria-hidden="true">
  <canvas data-web3d="routewonder" aria-label={label}></canvas>
</div>

<script>
  function setupRouteWonder3D() {
    const canvas = document.querySelector('canvas[data-web3d="routewonder"]');
    if (!canvas || canvas.dataset.ready === 'true') return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const coarse = window.matchMedia('(pointer: coarse)').matches;
    if (reduced || coarse) return;
    canvas.dataset.ready = 'true';

    import('three').then((THREE) => {
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 100);
      camera.position.set(0, 1.3, 5.8);

      const group = new THREE.Group();
      scene.add(group);

      const paper = new THREE.LineBasicMaterial({ color: 0xa34f3f, transparent: true, opacity: 0.38 });
      const route = new THREE.LineBasicMaterial({ color: 0x445c3f, transparent: true, opacity: 0.86 });
      const gold = new THREE.LineBasicMaterial({ color: 0xb8874c, transparent: true, opacity: 0.5 });

      for (let i = -3; i <= 3; i++) {
        const z = Math.sin(i * 0.9) * 0.12;
        group.add(new THREE.Line(
          new THREE.BufferGeometry().setFromPoints([
            new THREE.Vector3(-2.7, i * 0.42, z),
            new THREE.Vector3(2.7, i * 0.42, -z),
          ]),
          paper,
        ));
        group.add(new THREE.Line(
          new THREE.BufferGeometry().setFromPoints([
            new THREE.Vector3(i * 0.82, -1.35, -z),
            new THREE.Vector3(i * 0.82, 1.35, z),
          ]),
          gold,
        ));
      }

      const curve = new THREE.CatmullRomCurve3([
        new THREE.Vector3(-2.35, -0.85, 0.22),
        new THREE.Vector3(-1.15, 0.55, -0.08),
        new THREE.Vector3(0.15, -0.18, 0.28),
        new THREE.Vector3(1.15, 0.82, -0.04),
        new THREE.Vector3(2.22, -0.48, 0.18),
      ]);
      group.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(curve.getPoints(80)), route));

      const resize = () => {
        const rect = canvas.getBoundingClientRect();
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.6));
        renderer.setSize(rect.width, rect.height, false);
        camera.aspect = rect.width / Math.max(1, rect.height);
        camera.updateProjectionMatrix();
      };

      const clock = new THREE.Clock();
      const animate = () => {
        const t = clock.getElapsedTime();
        group.rotation.x = -0.18 + Math.sin(t * 0.5) * 0.025;
        group.rotation.y = Math.sin(t * 0.32) * 0.18;
        group.position.y = Math.sin(t * 0.42) * 0.045;
        renderer.render(scene, camera);
        requestAnimationFrame(animate);
      };

      resize();
      window.addEventListener('resize', resize, { passive: true });
      animate();
    }).catch(() => {});
  }

  window.addEventListener('load', setupRouteWonder3D, { once: true });
  document.addEventListener('astro:after-swap', setupRouteWonder3D);
</script>
