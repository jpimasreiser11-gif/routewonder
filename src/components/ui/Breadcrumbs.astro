---
export interface Props {
  items: Array<{
    label: string;
    href?: string;
  }>;
}

const { items } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<nav class="flex mb-6 font-ui text-xs text-rw-ocean/60 dark:text-rw-mist/60" aria-label="Breadcrumb">
  <ol class="inline-flex items-center space-x-1 md:space-x-2">
    <li class="inline-flex items-center">
      <a href={base} class="hover:text-rw-horizon flex items-center gap-1 transition-colors">
        <span>🗺️</span> Home
      </a>
    </li>
    {
      items.map((item, index) => (
        <li class="flex items-center">
          <span class="mx-1 md:mx-2 select-none text-rw-mist/40 font-mono">/</span>
          {item.href ? (
            <a href={item.href} class="hover:text-rw-horizon transition-colors">
              {item.label}
            </a>
          ) : (
            <span class="text-rw-ink dark:text-rw-sand font-medium" aria-current="page">
              {item.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
