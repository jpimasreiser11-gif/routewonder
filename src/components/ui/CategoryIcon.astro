---
export interface Props {
  icon: string;
  class?: string;
}

const { icon, class: className = "w-5 h-5" } = Astro.props;

const icons: Record<string, string> = {
  all: '<path d="M12 3l2.35 5.35L20 9l-4.25 3.7L17 18.5 12 15.45 7 18.5l1.25-5.8L4 9l5.65-.65L12 3z"/><path d="M4.5 20.5h15" opacity=".45"/>',
  route: '<path d="M4 17.5c3-5.5 6.5 2.5 9.5-3.5s4.5-4.5 6.5-8"/><circle cx="4" cy="17.5" r="2"/><circle cx="20" cy="6" r="2"/><path d="M9 6.5l2.5-3 2.5 3"/><path d="M11.5 3.5v8"/>',
  city: '<path d="M4 20V9l5-3v14"/><path d="M9 20V4l6 3v13"/><path d="M15 20v-8l5 2v6"/><path d="M6 11h1M6 14h1M11 8h1M11 11h1M17 15h1"/>',
  island: '<path d="M4 19c3-2 13-2 16 0"/><path d="M10 17c.8-4 2-8 6-12"/><path d="M15.5 5.5c-3.8-.7-6.2.5-7.5 3.5 3.4-.9 5.8-.2 7.5 1.5"/><path d="M16.5 5.3c1.4 2.5 1.1 4.8-.8 7 2.5-.8 4-2.4 4.3-4.8"/>',
  budget: '<circle cx="12" cy="12" r="8"/><path d="M15 8.5c-.8-.7-1.7-1-2.9-1-2.2 0-3.9 1.5-3.9 4.5s1.7 4.5 3.9 4.5c1.2 0 2.1-.3 2.9-1"/><path d="M6.5 11h6.8M6.5 13h6.1"/>',
  geo: '<path d="M4 6.5l5-2 6 2 5-2v13l-5 2-6-2-5 2v-13z"/><path d="M9 4.5v13M15 6.5v13"/><path d="M7 9.5h.01M12 12h.01M17 9h.01M17 15h.01"/>',
  cinema: '<path d="M5 6h14v12H5z"/><path d="M8 6l2-3h4l2 3"/><path d="M9 10l5 3-5 3v-6z"/>',
  fast: '<path d="M13 2L4 14h7l-1 8 10-13h-7l1-7z"/>',
};

const paths = icons[icon] || icons.route;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={paths}
/>
