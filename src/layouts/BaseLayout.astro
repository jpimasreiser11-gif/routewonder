---
import SEOHead from "../components/seo/SEOHead.astro";
import ConsentScripts from "../components/seo/ConsentScripts.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import MobileMenu from "../components/layout/MobileMenu.astro";
import CookieBanner from "../components/ui/CookieBanner.astro";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: string;
}

const { title, description, image, imageAlt, type } = Astro.props;
---

<html lang="es">
  <head>
    <SEOHead {title} {description} {image} {imageAlt} {type} />
    <ConsentScripts />
    <ClientRouter />
    
    <!-- Script to handle dark mode toggle local storage before rendering page -->
    <script is:inline>
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('color-theme')) {
          return localStorage.getItem('color-theme');
        }
        return 'light'; // Default to light mode (sand backgrounds)
      };
      
      const theme = getThemePreference();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="bg-rw-sand text-rw-ink dark:bg-rw-ink dark:text-rw-sand min-h-screen flex flex-col transition-colors duration-300">
    <!-- Header Navigation -->
    <Header />
    
    <!-- Mobile Menu Drawer Overlay -->
    <MobileMenu />

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer Information -->
    <Footer />

    <!-- GDPR Consent Banner -->
    <CookieBanner />

    <script is:inline>
      function setupRevealObserver() {
        const items = document.querySelectorAll('.reveal');
        if (!items.length) return;
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12 });
        items.forEach((item) => observer.observe(item));
      }
      setupRevealObserver();
      document.addEventListener('astro:after-swap', setupRevealObserver);
    </script>
    <script is:inline>
      function setupRouteWonderTilt() {
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const finePointer = window.matchMedia('(pointer: fine)').matches;
        if (reduceMotion || !finePointer) return;
        document.querySelectorAll('[data-rw-tilt-lite]').forEach((item) => {
          if (item.dataset.rwTiltReady === 'true') return;
          item.dataset.rwTiltReady = 'true';
          item.addEventListener('pointermove', (event) => {
            const rect = item.getBoundingClientRect();
            const x = (event.clientX - rect.left) / rect.width;
            const y = (event.clientY - rect.top) / rect.height;
            item.style.transform = `perspective(1100px) rotateX(${(0.5 - y) * 2.5}deg) rotateY(${(x - 0.5) * 3.5}deg)`;
          });
          item.addEventListener('pointerleave', () => {
            item.style.transform = '';
          });
        });
      }
      setupRouteWonderTilt();
      document.addEventListener('astro:after-swap', setupRouteWonderTilt);
    </script>
  </body>
</html>
